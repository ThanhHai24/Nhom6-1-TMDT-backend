        <div class="breadcrumb">
            <a href="#">Trang chủ</a> &gt; <a href="#">Giỏ hàng</a>
        </div>

        <!-- Empty Cart -->
        <% const hasItems = (locals.cart && locals.cart.length > 0); %>
        <div id="emptyCart" class="cart-container" style="display: <%= hasItems ? 'none' : 'block' %>;">
            <div class="cart-header">
                <h2 class="cart-title">Giỏ hàng của bạn</h2>
                <a href="/" class="continue-shopping">
                    ← Mua thêm sản phẩm khác
                </a>
            </div>
            <% if (locals.success_msg) { %>
                <div style="color: green; padding: 15px; margin-bottom: 20px; border: 1px solid green; border-radius: 5px;">
                    <%= success_msg %>
                </div>
            <% } %>
            <% if (locals.error_msg) { %>
                <div style="color: #c0392b; padding: 15px; margin-bottom: 20px; border: 1px solid #e74c3c; background:#fff5f5; border-radius: 5px;">
                    <strong>⚠️ Lỗi:</strong> <%= error_msg %>
                </div>
            <% } %>
            <div class="empty-cart">
                <div class="empty-cart-icon">
                    <div class="basket-icon">🛒</div>
                </div>
                <p class="empty-cart-message">Không có sản phẩm nào trong giỏ hàng của bạn.</p>
                <a href="/" class="shop-now-btn">TIẾP TỤC MUA SẮM</a>
            </div>
        </div>

        <!-- Cart with Items -->
        <div id="cartWithItems" class="cart-container" style="display: <%= hasItems ? 'block' : 'none' %>;">
            <div class="cart-header">
                <h2 class="cart-title">Giỏ hàng của bạn</h2>
                <a href="/" class="continue-shopping">
                    ← Mua thêm sản phẩm khác
                </a>
            </div>

            <% if (locals.error_msg) { %>
                <div style="color: #c0392b; padding: 15px; margin-bottom: 20px; border: 1px solid #e74c3c; background:#fff5f5; border-radius: 5px; display:flex; align-items:flex-start; gap:8px;">
                    <strong>⚠️</strong> <span><%= error_msg %></span>
                </div>
            <% } %>
            <% if (locals.success_msg) { %>
                <div style="color: green; padding: 15px; margin-bottom: 20px; border: 1px solid green; border-radius: 5px;">
                    <%= success_msg %>
                </div>
            <% } %>

            <div class="cart-content">
                <% 
                   let total = 0;
                   if (hasItems) {
                       locals.cart.forEach(item => { 
                           total += item.price * item.quantity;
                %>
                <div class="product-item">
                    <div class="product-image">
                        <img src="/admin/productImages/<%= item.image %>" alt="<%= item.name %>">
                    </div>
                    <div class="product-details">
                        <div>
                            <h3 class="product-title"><%= item.name %></h3>
                            <p class="product-promotion">Mã SP: <%= item.sku %></p>
                        </div>
                        
                        <div class="product-controls">
                            <form action="/cart/update" method="POST" class="quantity-control" style="margin:0;">
                                <input type="hidden" name="product_id" value="<%= item.productId %>">
                                <button type="submit" class="quantity-btn" onclick="this.form.quantity.value=Math.max(1, parseInt(this.form.quantity.value)-1)">-</button>
                                <input type="number" name="quantity" class="quantity-value" value="<%= item.quantity %>" min="1" style="width:30px; text-align:center; border:none; background:transparent; font-weight:bold; font-size:14px; pointer-events: none;" readonly tabindex="-1">
                                <button type="submit" class="quantity-btn" onclick="this.form.quantity.value=parseInt(this.form.quantity.value)+1">+</button>
                            </form>
                            <div class="product-price">
                                <div class="current-price"><%= item.price.toLocaleString('vi-VN') %> đ</div>
                            </div>
                            <form action="/cart/remove" method="POST" style="display:inline;">
                                <input type="hidden" name="product_id" value="<%= item.productId %>">
                                <button type="submit" class="remove-item"><i class="ri-delete-bin-line"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
                <% 
                       }); 
                   } else { 
                %>
                <!-- Mẫu rỗng khi chưa có sản phẩm (hiệu ứng test Toggle) -->
                <div class="product-item">
                    <div class="product-image">
                        <img src="assets/images/PC00001-1.jpg" alt="Laptop HP">
                    </div>
                    <div class="product-details">
                        <div>
                            <h3 class="product-title">Sản phẩm mẫu (Test Toggle)</h3>
                            <p class="product-promotion">Khuyến mại (Chi tiết ▼)</p>
                        </div>
                        
                        <div class="product-controls">
                            <div class="quantity-control">
                                <span class="quantity-value" id="quantity">1</span>
                            </div>
                            <div class="product-price">
                                <div class="current-price">3.490.000 đ</div>
                            </div>
                            <button type="button" class="remove-item"><i class="ri-delete-bin-line"></i></button>
                        </div>
                    </div>
                </div>
                <% } %>
            </div>

            <!-- Customer Information -->
            <form action="/cart/checkout" method="POST">
                <div class="customer-info">
                    <h3 class="section-title">THÔNG TIN KHÁCH HÀNG</h3>
                    <div class="form-grid full-width">
                        <div class="form-group">
                            <input type="text" name="customerName" class="form-control" placeholder="Họ tên*" required value="<%= locals.user ? user.fullName : '' %>">
                        </div>
                    </div>
                    <div class="form-grid">
                        <div class="form-group">
                            <input type="tel" name="customerPhone" class="form-control" placeholder="Số điện thoại*" required value="<%= locals.user ? user.phone : '' %>">
                        </div>
                        <div class="form-group">
                            <input type="email" name="customerEmail" class="form-control" placeholder="Email (Tùy chọn)" value="<%= locals.user ? user.email : '' %>">
                        </div>
                    </div>
                    <div class="form-grid" style="grid-template-columns: 1fr 1fr 1fr;">
                        <div class="form-group">
                            <select class="form-control" name="city" id="city" required>
                                <option value="">Tỉnh/Thành phố*</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <select class="form-control" name="district" id="district" required disabled>
                                <option value="">Quận/Huyện*</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <select class="form-control" name="ward" id="ward" required disabled>
                                <option value="">Phường/Xã*</option>
                            </select>
                        </div>
                    </div>
                    <!-- Hidden inputs for actual text names populated by their frontend JS if apiprovince works -->
                    <div class="form-grid full-width">
                        <div class="form-group">
                            <input type="text" name="address" class="form-control" placeholder="Số nhà, Tên đường*" required>
                        </div>
                    </div>
                    <div class="form-grid full-width">
                        <div class="form-group">
                            <textarea name="notes" class="form-control notes-textarea" placeholder="Ghi chú thêm (Ví dụ: Giao giờ hành chính)"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="payment-section">
                    <h3 class="section-title">PHƯƠNG THỨC THANH TOÁN</h3>

                    <!-- COD -->
                    <div class="payment-option" id="payment-opt-cod">
                        <input type="radio" id="cash" name="paymentMethod" value="COD" checked>
                        <label for="cash" style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                            <span style="font-size:22px;">💵</span>
                            <span>
                                <strong>Thanh toán khi nhận hàng (COD)</strong><br>
                                <small style="color:#888;">Trả tiền mặt khi nhận hàng</small>
                            </span>
                        </label>
                    </div>

                    <!-- VNPay -->
                    <div class="payment-option" id="payment-opt-vnpay" style="margin-top:10px; border:2px solid transparent; border-radius:8px; padding:12px; transition: border-color 0.2s;">
                        <input type="radio" id="vnpay" name="paymentMethod" value="VNPAY">
                        <label for="vnpay" style="display:flex; align-items:center; gap:10px; cursor:pointer;">
                            <img src="https://vnpay.vn/s1/statics/img/logo2.svg" alt="VNPay" style="height:28px; object-fit:contain;" onerror="this.style.display='none'">
                            <span>
                                <strong>Thanh toán qua VNPay</strong><br>
                                <small style="color:#888;">Thẻ ATM, Visa, MasterCard, QR Code</small>
                            </span>
                            <span style="margin-left:auto; background:#0066cc; color:white; font-size:11px; padding:2px 8px; border-radius:12px;">An toàn &amp; Nhanh</span>
                        </label>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="order-summary">
                    <h3 class="section-title">TỔNG TIỀN</h3>
                    <div class="summary-row">
                        <span>Tổng cộng</span>
                        <span id="subtotal"><%= total.toLocaleString('vi-VN') %> đ</span>
                    </div>
                    <div class="summary-row" id="shipping-fee-row" style="display: none;">
                        <span>Phí vận chuyển</span>
                        <span id="shipping-fee-amount">0 đ</span>
                    </div>
                    <div class="summary-row summary-total">
                        <span>Thành tiền</span>
                        <span id="total" style="color: #ff6b6b;"><%= total.toLocaleString('vi-VN') %> đ</span>
                    </div>
                    <input type="hidden" name="shippingFee" id="shippingFeeInput" value="0">
                    <button type="submit" id="place-order-btn" class="place-order-btn">ĐẶT HÀNG</button>
                </div>
            </form>
        </div>

    <script src="assets/js/scripts.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>
    <script>
        let serverTotal = <%= typeof total !== 'undefined' ? total : 0 %>;
        let currentShippingFee = 0;
        let isEmptyCart = true;
        let quantity = 1;
        const unitPrice = 3490000;

        function toggleCart() {
            const emptyCart = document.getElementById('emptyCart');
            const cartWithItems = document.getElementById('cartWithItems');
            if (isEmptyCart) {
                emptyCart.style.display = 'none';
                cartWithItems.style.display = 'block';
            } else {
                emptyCart.style.display = 'block';
                cartWithItems.style.display = 'none';
            }
            isEmptyCart = !isEmptyCart;
        }

        function changeQuantity(change) {
            quantity = Math.max(1, quantity + change);
            document.getElementById('quantity').textContent = quantity;
            updateTotal();
        }

        function updateTotal() {
            let baseTotal = serverTotal > 0 ? serverTotal : quantity * unitPrice;
            let finalTotal = baseTotal + currentShippingFee;
            document.getElementById('subtotal').textContent = baseTotal.toLocaleString('vi-VN') + ' đ';
            document.getElementById('total').textContent = finalTotal.toLocaleString('vi-VN') + ' đ';
        }

        function removeItem() {
            if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')) {
                toggleCart();
            }
        }

        document.addEventListener('DOMContentLoaded', async function() {

            // ── 1. Payment method UI ──────────────────────────────────────────
            const paymentRadios = document.querySelectorAll('input[name="paymentMethod"]');
            const orderBtn = document.getElementById('place-order-btn');

            function updatePaymentUI() {
                const selected = document.querySelector('input[name="paymentMethod"]:checked');
                if (!selected) return;

                document.querySelectorAll('.payment-option').forEach(el => {
                    el.style.borderColor = 'transparent';
                    el.style.background = '';
                });

                const parent = selected.closest('.payment-option');
                parent.style.borderColor = '#0066cc';
                parent.style.background = 'rgba(0,102,204,0.04)';

                if (selected.value === 'VNPAY') {
                    orderBtn.textContent = 'THANH TOÁN QUA VNPAY →';
                    orderBtn.style.background = 'linear-gradient(135deg, #0052cc, #0099ff)';
                } else {
                    orderBtn.textContent = 'ĐẶT HÀNG';
                    orderBtn.style.background = '';
                }
            }

            paymentRadios.forEach(r => r.addEventListener('change', updatePaymentUI));
            updatePaymentUI();

            // ── 2. Empty cart icon animation ──────────────────────────────────
            const emptyIcon = document.querySelector('.empty-cart-icon');
            if (emptyIcon) {
                setInterval(() => {
                    emptyIcon.style.transform = 'scale(1.05)';
                    setTimeout(() => { emptyIcon.style.transform = 'scale(1)'; }, 200);
                }, 3000);
            }

            // ── 3. Tỉnh / Thành phố / Quận / Phường ─────────────────────────
            const citySelect = document.getElementById('city');
            const districtSelect = document.getElementById('district');
            const wardSelect = document.getElementById('ward');

            if (!citySelect) return; // giỏ trống, không có form

            try {
                const res = await axios.get('/api/locations/provinces');
                const provinces = res.data.data;
                if (provinces) {
                    provinces.forEach(p => {
                        const option = document.createElement('option');
                        option.value = p.ProvinceName;
                        option.dataset.id = p.ProvinceID;
                        option.textContent = p.ProvinceName;
                        citySelect.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error fetching provinces:', error);
            }

            citySelect.addEventListener('change', async function() {
                districtSelect.innerHTML = '<option value="">Quận/Huyện*</option>';
                wardSelect.innerHTML = '<option value="">Phường/Xã*</option>';
                districtSelect.disabled = true;
                wardSelect.disabled = true;

                const selectedOption = citySelect.options[citySelect.selectedIndex];
                const provinceId = selectedOption.dataset.id;

                if (provinceId) {
                    try {
                        const res = await axios.get(`/api/locations/districts?province_id=${provinceId}`);
                        const districts = res.data.data;
                        if (districts) {
                            districts.forEach(d => {
                                const option = document.createElement('option');
                                option.value = d.DistrictName;
                                option.dataset.id = d.DistrictID;
                                option.textContent = d.DistrictName;
                                districtSelect.appendChild(option);
                            });
                            districtSelect.disabled = false;
                        }
                    } catch (error) {
                        console.error('Error fetching districts:', error);
                    }
                }
            });

            districtSelect.addEventListener('change', async function() {
                wardSelect.innerHTML = '<option value="">Phường/Xã*</option>';
                wardSelect.disabled = true;

                const selectedOption = districtSelect.options[districtSelect.selectedIndex];
                const districtId = selectedOption.dataset.id;

                if (districtId) {
                    try {
                        const res = await axios.get(`/api/locations/wards?district_id=${districtId}`);
                        const wards = res.data.data;
                        if (wards) {
                            wards.forEach(w => {
                                const option = document.createElement('option');
                                option.value = w.WardName;
                                option.dataset.id = w.WardCode;
                                option.textContent = w.WardName;
                                wardSelect.appendChild(option);
                            });
                            wardSelect.disabled = false;
                        }
                    } catch (error) {
                        console.error('Error fetching wards:', error);
                    }
                }
            });

            wardSelect.addEventListener('change', async function() {
                const selectedDistrict = districtSelect.options[districtSelect.selectedIndex];
                const selectedWard = wardSelect.options[wardSelect.selectedIndex];
                const districtId = selectedDistrict.dataset.id;
                const wardCode = selectedWard.dataset.id;

                if (districtId && wardCode) {
                    try {
                        const res = await axios.post('/api/shipping/fee', {
                            to_district_id: districtId,
                            to_ward_code: wardCode
                        });

                        if (res.data && res.data.data && res.data.data.total) {
                            currentShippingFee = res.data.data.total;
                            document.getElementById('shipping-fee-row').style.display = 'flex';
                            document.getElementById('shipping-fee-amount').textContent = currentShippingFee.toLocaleString('vi-VN') + ' đ';
                            document.getElementById('shippingFeeInput').value = currentShippingFee;
                            updateTotal();
                        }
                    } catch (error) {
                        console.error('Error calculating shipping fee:', error);
                        currentShippingFee = 0;
                        document.getElementById('shipping-fee-row').style.display = 'none';
                        document.getElementById('shippingFeeInput').value = 0;
                        updateTotal();
                    }
                } else {
                    currentShippingFee = 0;
                    document.getElementById('shipping-fee-row').style.display = 'none';
                    document.getElementById('shippingFeeInput').value = 0;
                    updateTotal();
                }
            });
        });
    </script>

