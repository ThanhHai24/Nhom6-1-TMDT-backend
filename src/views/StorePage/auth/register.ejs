
    <div class="wrapper">
        <main>
            <div class="auth-card" style="margin: 0 auto; margin-top: 20px;">
            <div class="auth-card-header">
                <div class="icon-wrap"><i class="ri-user-add-fill"></i></div>
                <h1>Tạo Tài Khoản</h1>
                <p>Đăng ký ngay để nhận nhiều ưu đãi hấp dẫn từ PCStore</p>
            </div>
            <div class="auth-card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error" style="display: block; margin-bottom: 20px;">
                    <i class="ri-error-warning-line"></i> <%= error %>
                </div>
                <% } %>
                <form action="/register" method="POST" id="registerForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="ho">Họ</label>
                            <div class="input-wrap">
                                <i class="ri-user-line field-icon"></i>
                                <input type="text" id="ho" name="ho" placeholder="Nguyễn" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="ten">Tên</label>
                            <div class="input-wrap">
                                <i class="ri-user-line field-icon"></i>
                                <input type="text" id="ten" name="ten" placeholder="Văn A" required>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <div class="input-wrap">
                            <i class="ri-mail-line field-icon"></i>
                            <input type="email" id="email" name="email" placeholder="example@email.com" required>
                        </div>
                        <div class="error-msg" id="emailError">Email không hợp lệ.</div>
                    </div>
                    <div class="form-group">
                        <label for="phone">Số điện thoại</label>
                        <div class="input-wrap">
                            <i class="ri-phone-line field-icon"></i>
                            <input type="tel" id="phone" name="phone" placeholder="0901 234 567" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="password">Mật khẩu</label>
                        <div class="input-wrap">
                            <i class="ri-lock-line field-icon"></i>
                            <input type="password" id="password" name="password" placeholder="Tối thiểu 8 ký tự" required oninput="checkStrength(this.value)">
                            <i class="ri-eye-off-line toggle-pw" id="togglePw1" onclick="togglePw('password','togglePw1')"></i>
                        </div>
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div class="strength-text" id="strengthText"></div>
                    </div>
                    <div class="form-group">
                        <label for="confirm_password">Xác nhận mật khẩu</label>
                        <div class="input-wrap">
                            <i class="ri-lock-password-line field-icon"></i>
                            <input type="password" id="confirm_password" name="confirm_password" placeholder="Nhập lại mật khẩu" required>
                            <i class="ri-eye-off-line toggle-pw" id="togglePw2" onclick="togglePw('confirm_password','togglePw2')"></i>
                        </div>
                        <div class="error-msg" id="pwMatchError">Mật khẩu không khớp.</div>
                    </div>
 
                    <div class="terms">
                        <input type="checkbox" id="terms" name="terms" required>
                        <label for="terms">Tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a> của PCStore</label>
                    </div>
 
                    <button type="submit" class="btn-primary">
                        <i class="ri-user-add-line"></i> Đăng Ký Ngay
                    </button>
                </form>
 
                <div class="divider">hoặc đăng ký với</div>
                <button class="btn-social btn-google" onclick="alert('Đăng ký Google')">
                    <i class="bi bi-google"></i> Tiếp tục với Google
                </button>
 
                <div class="auth-footer">
                    Đã có tài khoản? <a href="/login">Đăng nhập ngay</a>
                </div>
            </div>
        </div>

        </main>

    </div>
<script>
function togglePassword() {
    const pw = document.getElementById('password');
    const icon = document.getElementById('togglePw');
    if (pw.type === 'password') { pw.type = 'text'; icon.className = 'ri-eye-line toggle-pw'; }
    else { pw.type = 'password'; icon.className = 'ri-eye-off-line toggle-pw'; }
}
</script>
