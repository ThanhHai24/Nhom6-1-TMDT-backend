<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>
    <title>PCStore - Cửa hàng máy tính</title>
    <link rel="stylesheet" href="client/css/style.css">
    <style>
        :root {
            --main-bg: url("/client/images/backweb.webp"

                );
            --promotion-bg: url({{asset('homepage/assets/images/background_offer_detail.png')
        }
        });
        }
    </style>
    <style>
    .auth-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(30,80,220,0.12);
            width: 100%;
            max-width: 520px;
            overflow: hidden;
        }
        .auth-card-header {
            background: linear-gradient(135deg, #2E9BFB 0%, #1D52E7 100%);
            padding: 32px 36px 28px;
            text-align: center;
            color: white;
        }
        .auth-card-header .icon-wrap {
            width: 64px; height: 64px; background: rgba(255,255,255,0.2);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
        }
        .auth-card-header .icon-wrap i { font-size: 32px; color: white; }
        .auth-card-header h1 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
        .auth-card-header p { font-size: 14px; opacity: 0.88; }
 
        .auth-card-body { padding: 36px; }
 
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 14px; font-weight: 600; color: #333; margin-bottom: 7px; }
        .input-wrap { position: relative; }
        .input-wrap i.field-icon { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #999; font-size: 18px; pointer-events: none; }
        .input-wrap input, .input-wrap select {
            width: 100%; padding: 13px 14px 13px 42px;
            border: 1.5px solid #dde3f0; border-radius: 8px;
            font-size: 15px; color: #222; background: #fafbff;
            transition: border-color 0.2s, box-shadow 0.2s;
            appearance: none;
        }
        .input-wrap input:focus, .input-wrap select:focus { outline: none; border-color: #2E9BFB; box-shadow: 0 0 0 3px rgba(46,155,251,0.12); background: white; }
        .input-wrap .toggle-pw { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #aaa; font-size: 18px; }
        .input-wrap .toggle-pw:hover { color: #2E9BFB; }
 
        .strength-bar { height: 4px; border-radius: 2px; background: #eee; margin-top: 8px; overflow: hidden; }
        .strength-fill { height: 100%; border-radius: 2px; width: 0%; transition: width 0.3s, background 0.3s; }
        .strength-text { font-size: 12px; margin-top: 4px; color: #999; }
 
        .terms { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 22px; font-size: 14px; color: #555; }
        .terms input[type="checkbox"] { accent-color: #1D52E7; width: 16px; height: 16px; margin-top: 2px; flex-shrink: 0; cursor: pointer; }
        .terms a { color: #1D52E7; font-weight: 600; }
        .terms a:hover { text-decoration: underline; }
 
        .btn-primary {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, #2E9BFB 0%, #1D52E7 100%);
            color: white; border: none; border-radius: 8px;
            font-size: 16px; font-weight: 700; cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
        }
        .btn-primary:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(29,82,231,0.25); }
 
        .divider { display: flex; align-items: center; gap: 12px; margin: 24px 0; color: #aaa; font-size: 13px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #eee; }
 
        .btn-social {
            width: 100%; padding: 12px; background: white; color: #333;
            border: 1.5px solid #dde3f0; border-radius: 8px;
            font-size: 14px; font-weight: 600; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .btn-social:hover { border-color: #2E9BFB; box-shadow: 0 2px 8px rgba(46,155,251,0.1); }
        .btn-google i { color: #EA4335; font-size: 20px; }
 
        .auth-footer { text-align: center; margin-top: 24px; font-size: 14px; color: #666; }
        .auth-footer a { color: #1D52E7; font-weight: 700; }
        .auth-footer a:hover { text-decoration: underline; }
 
        .input-error { border-color: #e53935 !important; }
        .error-msg { font-size: 12px; color: #e53935; margin-top: 4px; display: none; }
 
        @media (max-width: 520px) {
            .form-row { grid-template-columns: 1fr; }
            .auth-card-body { padding: 24px; }
        }
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 40px rgba(30, 80, 220, 0.12);
            width: 100%;
            max-width: 460px;
            overflow: hidden;
        }
        .auth-card-header {
            background: linear-gradient(135deg, #2E9BFB 0%, #1D52E7 100%);
            padding: 32px 36px 28px;
            text-align: center;
            color: white;
        }
        .auth-card-header .icon-wrap {
            width: 64px; height: 64px; background: rgba(255,255,255,0.2);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 16px;
        }
        .auth-card-header .icon-wrap i { font-size: 32px; color: white; }
        .auth-card-header h1 { font-size: 26px; font-weight: 700; margin-bottom: 6px; }
        .auth-card-header p { font-size: 14px; opacity: 0.88; }
 
        .auth-card-body { padding: 36px; }
 
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; font-size: 14px; font-weight: 600; color: #333; margin-bottom: 7px; }
        .input-wrap { position: relative; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #999; font-size: 18px; }
        .input-wrap input {
            width: 100%; padding: 13px 14px 13px 42px;
            border: 1.5px solid #dde3f0; border-radius: 8px;
            font-size: 15px; color: #222; background: #fafbff;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .input-wrap input:focus { outline: none; border-color: #2E9BFB; box-shadow: 0 0 0 3px rgba(46,155,251,0.12); background: white; }
        .input-wrap .toggle-pw { left: auto; right: 14px; cursor: pointer; color: #aaa; }
        .input-wrap .toggle-pw:hover { color: #2E9BFB; }
 
        .form-options { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; font-size: 14px; }
        .remember-me { display: flex; align-items: center; gap: 7px; color: #555; cursor: pointer; }
        .remember-me input[type="checkbox"] { accent-color: #1D52E7; width: 16px; height: 16px; cursor: pointer; }
        .forgot-link { color: #1D52E7; font-weight: 600; }
        .forgot-link:hover { text-decoration: underline; }
 
        .btn-primary {
            width: 100%; padding: 14px;
            background: linear-gradient(135deg, #2E9BFB 0%, #1D52E7 100%);
            color: white; border: none; border-radius: 8px;
            font-size: 16px; font-weight: 700; cursor: pointer;
            transition: opacity 0.2s, transform 0.2s;
            letter-spacing: 0.3px;
        }
        .btn-primary:hover { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(29,82,231,0.25); }
 
        .divider { display: flex; align-items: center; gap: 12px; margin: 24px 0; color: #aaa; font-size: 13px; }
        .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #eee; }
 
        .btn-social {
            width: 100%; padding: 12px;
            background: white; color: #333;
            border: 1.5px solid #dde3f0; border-radius: 8px;
            font-size: 14px; font-weight: 600; cursor: pointer;
            display: flex; align-items: center; justify-content: center; gap: 10px;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .btn-social:hover { border-color: #2E9BFB; box-shadow: 0 2px 8px rgba(46,155,251,0.1); }
        .btn-social i { font-size: 20px; }
        .btn-google i { color: #EA4335; }
 
        .auth-footer { text-align: center; margin-top: 24px; font-size: 14px; color: #666; }
        .auth-footer a { color: #1D52E7; font-weight: 700; }
        .auth-footer a:hover { text-decoration: underline; }
 
        .alert { padding: 12px 16px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; display: none; }
        .alert-error { background: #fff0f0; border: 1px solid #ffcdd2; color: #c62828; }</style>
</head>

<body>
    <div class="wrapper">
        <header>
            <%- include("../layout/header.ejs") %>
        </header>

        <nav class="main-nav">
            <%- include("../layout/navbar.ejs") %>
        </nav>

        <main>
            <div class="auth-card" style="margin: 0 auto; margin-top: 20px;">
            <div class="auth-card-header">
                <div class="icon-wrap"><i class="ri-user-add-fill"></i></div>
                <h1>Tạo Tài Khoản</h1>
                <p>Đăng ký ngay để nhận nhiều ưu đãi hấp dẫn từ PCStore</p>
            </div>
            <div class="auth-card-body">
                <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-error" style="display: block; margin-bottom: 20px;">
                    <i class="ri-error-warning-line"></i> <%= error %>
                </div>
                <% } %>
                <form action="/register" method="POST" id="registerForm">
                    <div class="form-row">
                        <div class="form-group">
                            <label for="ho">Họ</label>
                            <div class="input-wrap">
                                <i class="ri-user-line field-icon"></i>
                                <input type="text" id="ho" name="ho" placeholder="Nguyễn" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="ten">Tên</label>
                            <div class="input-wrap">
                                <i class="ri-user-line field-icon"></i>
                                <input type="text" id="ten" name="ten" placeholder="Văn A" required>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <div class="input-wrap">
                            <i class="ri-mail-line field-icon"></i>
                            <input type="email" id="email" name="email" placeholder="example@email.com" required>
                        </div>
                        <div class="error-msg" id="emailError">Email không hợp lệ.</div>
                    </div>
                    <div class="form-group">
                        <label for="phone">Số điện thoại</label>
                        <div class="input-wrap">
                            <i class="ri-phone-line field-icon"></i>
                            <input type="tel" id="phone" name="phone" placeholder="0901 234 567" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="password">Mật khẩu</label>
                        <div class="input-wrap">
                            <i class="ri-lock-line field-icon"></i>
                            <input type="password" id="password" name="password" placeholder="Tối thiểu 8 ký tự" required oninput="checkStrength(this.value)">
                            <i class="ri-eye-off-line toggle-pw" id="togglePw1" onclick="togglePw('password','togglePw1')"></i>
                        </div>
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <div class="strength-text" id="strengthText"></div>
                    </div>
                    <div class="form-group">
                        <label for="confirm_password">Xác nhận mật khẩu</label>
                        <div class="input-wrap">
                            <i class="ri-lock-password-line field-icon"></i>
                            <input type="password" id="confirm_password" name="confirm_password" placeholder="Nhập lại mật khẩu" required>
                            <i class="ri-eye-off-line toggle-pw" id="togglePw2" onclick="togglePw('confirm_password','togglePw2')"></i>
                        </div>
                        <div class="error-msg" id="pwMatchError">Mật khẩu không khớp.</div>
                    </div>
 
                    <div class="terms">
                        <input type="checkbox" id="terms" name="terms" required>
                        <label for="terms">Tôi đồng ý với <a href="#">Điều khoản dịch vụ</a> và <a href="#">Chính sách bảo mật</a> của PCStore</label>
                    </div>
 
                    <button type="submit" class="btn-primary">
                        <i class="ri-user-add-line"></i> Đăng Ký Ngay
                    </button>
                </form>
 
                <div class="divider">hoặc đăng ký với</div>
                <button class="btn-social btn-google" onclick="alert('Đăng ký Google')">
                    <i class="bi bi-google"></i> Tiếp tục với Google
                </button>
 
                <div class="auth-footer">
                    Đã có tài khoản? <a href="/login">Đăng nhập ngay</a>
                </div>
            </div>
        </div>

        </main>

        <footer>
            <%- include("../layout/footer.ejs") %>
        </footer>
    </div>

</body>
<script>
function togglePassword() {
    const pw = document.getElementById('password');
    const icon = document.getElementById('togglePw');
    if (pw.type === 'password') { pw.type = 'text'; icon.className = 'ri-eye-line toggle-pw'; }
    else { pw.type = 'password'; icon.className = 'ri-eye-off-line toggle-pw'; }
}
</script>
</html>