<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thanh toán thất bại - PCStore</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="/client/css/style.css">
    <style>
        body { background: #f5f7fa; }
        .payment-result-page {
            min-height: 70vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }
        .result-card {
            background: white;
            border-radius: 20px;
            padding: 60px 50px;
            max-width: 520px;
            width: 100%;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0,0,0,0.08);
            animation: fadeInUp 0.5s ease;
        }
        @keyframes fadeInUp {
            from { opacity:0; transform: translateY(30px); }
            to   { opacity:1; transform: translateY(0); }
        }
        .result-icon {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, #ff5252, #ff1744);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 28px;
            font-size: 48px;
            box-shadow: 0 8px 25px rgba(255,82,82,0.35);
            animation: shake 0.5s ease 0.3s;
        }
        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-8px); }
            40%       { transform: translateX(8px); }
            60%       { transform: translateX(-5px); }
            80%       { transform: translateX(5px); }
        }
        .result-title {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 12px;
        }
        .result-subtitle {
            font-size: 16px;
            color: #666;
            line-height: 1.6;
            margin-bottom: 32px;
        }
        .error-info {
            background: #fff5f5;
            border: 1px solid #ffd0d0;
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 32px;
            text-align: left;
        }
        .error-info-row {
            display: flex;
            justify-content: space-between;
            padding: 6px 0;
            font-size: 14px;
            color: #444;
            border-bottom: 1px solid #ffe0e0;
        }
        .error-info-row:last-child { border-bottom: none; }
        .error-info-row strong { color: #c0392b; }
        .result-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }
        .btn-retry {
            background: linear-gradient(135deg, #0052cc, #0099ff);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .btn-retry:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,82,204,0.4);
            color: white;
        }
        .btn-home {
            background: transparent;
            color: #555;
            border: 2px solid #ddd;
            padding: 14px 28px;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-home:hover {
            border-color: #555;
            color: #333;
        }
        .help-text {
            margin-top: 24px;
            font-size: 13px;
            color: #999;
        }
        .help-text a { color: #0066cc; }
    </style>
</head>
<body>
    <header>
        <%- include("../layout/header.ejs") %>
    </header>
    <nav class="main-nav">
        <%- include("../layout/navbar.ejs") %>
    </nav>

    <div class="payment-result-page">
        <div class="result-card">
            <div class="result-icon">✕</div>

            <h1 class="result-title">Thanh toán thất bại</h1>
            <p class="result-subtitle">
                Rất tiếc, giao dịch của bạn không được hoàn tất.<br>
                Đơn hàng vẫn được lưu và bạn có thể thử lại.
            </p>

            <div class="error-info">
                <% if (locals.orderCode) { %>
                <div class="error-info-row">
                    <span>Mã đơn hàng</span>
                    <strong>#<%= orderCode %></strong>
                </div>
                <% } %>
                <% if (locals.errorCode) { %>
                <div class="error-info-row">
                    <span>Mã lỗi VNPay</span>
                    <strong><%= errorCode %></strong>
                </div>
                <% } %>
                <% if (locals.errorMessage) { %>
                <div class="error-info-row">
                    <span>Lý do</span>
                    <strong style="color:#c0392b; text-align:right; max-width:65%;"><%= errorMessage %></strong>
                </div>
                <% } %>
                <div class="error-info-row">
                    <span>Trạng thái thanh toán</span>
                    <strong>✕ Thất bại / Bị huỷ</strong>
                </div>
            </div>

            <div class="result-actions">
                <% if (locals.canRetry && locals.orderCode) { %>
                    <%
                        // canRetry: khách hủy (24) hoặc timeout (11) → đơn vẫn PENDING, cho thanh toán lại
                    %>
                    <a href="/cart" class="btn-retry">
                        <i class="ri-refresh-line"></i> Thanh toán lại
                    </a>
                <% } else if (locals.orderCode) { %>
                    <a href="/orders/<%= orderCode %>" class="btn-retry">
                        Xem chi tiết đơn hàng
                    </a>
                <% } else { %>
                    <a href="/cart" class="btn-retry">Quay lại giỏ hàng</a>
                <% } %>
                <a href="/" class="btn-home">Về trang chủ</a>
            </div>


            <p class="help-text">
                Gặp vấn đề? <a href="tel:19001234">Liên hệ hotline 1900 1234</a>
            </p>
        </div>
    </div>

    <footer>
        <%- include("../layout/footer.ejs") %>
    </footer>
</body>
</html>
