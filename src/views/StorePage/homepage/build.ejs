    <!-- Modal chọn linh kiện -->
    <div id="componentModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title" id="modalTitle">Chọn linh kiện</h2>
                <button class="close" onclick="closeModal()">&times;</button>
            </div>
            <div class="modal-body">
                <!-- Toolbar: search + sort + filter by brand + filter by price -->
                <div class="modal-toolbar">
                    <input type="text" id="modalSearch" class="search-box" placeholder="Tìm kiếm sản phẩm...">
                    <select id="modalBrand" class="sort-select">
                        <option value="">Tất cả hãng</option>
                    </select>
                    <select id="modalPrice" class="sort-select">
                        <option value="">Tất cả mức giá</option>
                        <option value="under_2m">Dưới 2 triệu</option>
                        <option value="2m_5m">2 triệu - 5 triệu</option>
                        <option value="5m_10m">5 triệu - 10 triệu</option>
                        <option value="10m_20m">10 triệu - 20 triệu</option>
                        <option value="over_20m">Trên 20 triệu</option>
                    </select>
                    <select id="modalSort" class="sort-select">
                        <option value="">Mặc định</option>
                        <option value="price_asc">Giá thấp → cao</option>
                        <option value="price_desc">Giá cao → thấp</option>
                        <option value="name_asc">Tên A → Z</option>
                    </select>
                </div>

                <!-- Danh sách sản phẩm -->
                <div class="product-list" id="modalProductList">
                    <div class="loading-state">
                        <i class="ri-loader-4-line"></i>
                        Đang tải sản phẩm...
                    </div>
                </div>

                <!-- Phân trang -->
                <div class="modal-pagination" id="modalPagination"></div>
            </div>
        </div>
    </div>

    <script>
    // =========================================================
    // STATE
    // =========================================================
    const buildState = {
        selectedComponents: {}, // { slotKey: { id, name, price, image, sku, qty } }
        currentSlot: null,      // slot key đang mở modal
        currentCategory: null,  // category slug đang load
        currentPage: 1,
        searchTimer: null,
    };

    // Map slotKey → label để dùng lại khi reset
    const SLOT_LABELS = {
        cpu: 'Chọn CPU - Bộ Vi Xử Lý',
        mainboard: 'Chọn Main - Bo Mạch Chủ',
        ram: 'Chọn RAM - Bộ Nhớ Trong',
        ssd1: 'Chọn Ổ Cứng SSD 1',
        ssd2: 'Chọn Ổ Cứng SSD 2',
        vga: 'Chọn VGA - Card Màn Hình',
        psu: 'Chọn PSU - Nguồn Máy Tính',
        case: 'Chọn Case - Vỏ Máy Tính',
        cooling: 'Chọn Tản Nhiệt Khí',
        casefan: 'Chọn Quạt Tản Nhiệt',
        monitor: 'Chọn Monitor - Màn Hình',
        keyboard: 'Chọn Bàn Phím',
        mouse: 'Chọn Chuột',
        headphone: 'Chọn Tai Nghe',
    };
    const SLOT_CATEGORY = {
        cpu: 'cpu-bo-vi-xu-ly',
        mainboard: 'mainboard-bo-mach-chu',
        ram: 'ram-bo-nho-trong',
        ssd1: 'o-cung-hdd-ssd',
        ssd2: 'o-cung-hdd-ssd',
        vga: 'vga-card-do-hoa',
        psu: 'psu-nguon-may-tinh',
        case: 'case-vo-may-tinh',
        cooling: 'tan-nhiet-pc',
        casefan: 'quat-tan-nhiet',
        monitor: 'man-hinh',
        keyboard: 'ban-phim',
        mouse: 'chuot',
        headphone: 'tai-nghe',
    };

    // =========================================================
    // OPEN / CLOSE MODAL
    // =========================================================
    function openModal(slotKey, categorySlug) {
        buildState.currentSlot = slotKey;
        buildState.currentCategory = categorySlug || SLOT_CATEGORY[slotKey] || '';
        buildState.currentPage = 1;

        // Title
        document.getElementById('modalTitle').textContent = SLOT_LABELS[slotKey] || 'Chọn linh kiện';

        // Reset search & sort & filters
        document.getElementById('modalSearch').value = '';
        document.getElementById('modalSort').value = '';
        document.getElementById('modalBrand').innerHTML = '<option value="">Tất cả hãng</option>';
        document.getElementById('modalPrice').value = '';

        // Show modal
        document.getElementById('componentModal').style.display = 'block';
        document.body.style.overflow = 'hidden';

        // Load products (updating dynamic brands)
        loadProducts(1, true);
    }

    function closeModal() {
        document.getElementById('componentModal').style.display = 'none';
        document.body.style.overflow = 'auto';
        buildState.currentSlot = null;
    }

    // =========================================================
    // LOAD PRODUCTS FROM API
    // =========================================================
    async function loadProducts(page = 1, shouldUpdateBrands = false) {
        buildState.currentPage = page;
        const search = document.getElementById('modalSearch').value.trim();
        const sort = document.getElementById('modalSort').value;
        const brand = document.getElementById('modalBrand').value;
        const priceRange = document.getElementById('modalPrice').value;

        const listEl = document.getElementById('modalProductList');
        listEl.innerHTML = `<div class="loading-state"><i class="ri-loader-4-line"></i>Đang tải...</div>`;
        document.getElementById('modalPagination').innerHTML = '';

        try {
            const params = new URLSearchParams({
                category: buildState.currentCategory,
                page: page,
                limit: 8,
            });
            if (search) params.append('search', search);
            if (sort) params.append('sort', sort);
            if (brand) params.append('brand', brand);

            // Parse price range selection
            if (priceRange) {
                let minPrice = 0;
                let maxPrice = 0;
                if (priceRange === 'under_2m') {
                    maxPrice = 2000000;
                } else if (priceRange === '2m_5m') {
                    minPrice = 2000000;
                    maxPrice = 5000000;
                } else if (priceRange === '5m_10m') {
                    minPrice = 5000000;
                    maxPrice = 10000000;
                } else if (priceRange === '10m_20m') {
                    minPrice = 10000000;
                    maxPrice = 20000000;
                } else if (priceRange === 'over_20m') {
                    minPrice = 20000000;
                }
                if (minPrice) params.append('minPrice', minPrice);
                if (maxPrice) params.append('maxPrice', maxPrice);
            }

            const res = await fetch(`/api/products/by-category?${params}`);
            if (!res.ok) throw new Error('Lỗi mạng');
            const data = await res.json();

            renderProducts(data.products);
            renderPagination(data.currentPage, data.totalPages);

            if (shouldUpdateBrands) {
                updateBrandDropdown(data.brands || []);
            }
        } catch (err) {
            listEl.innerHTML = `<div class="empty-state"><i class="ri-error-warning-line"></i>Không thể tải sản phẩm. Vui lòng thử lại.</div>`;
        }
    }

    function updateBrandDropdown(brands) {
        const brandSelect = document.getElementById('modalBrand');
        const selectedValue = brandSelect.value;
        brandSelect.innerHTML = `<option value="">Tất cả hãng</option>` + 
            brands.map(b => `<option value="${escHtml(b.slug)}">${escHtml(b.name)}</option>`).join('');
        if (brands.some(b => b.slug === selectedValue)) {
            brandSelect.value = selectedValue;
        } else {
            brandSelect.value = '';
        }
    }

    function renderProducts(products) {
        const listEl = document.getElementById('modalProductList');
        if (!products || products.length === 0) {
            listEl.innerHTML = `<div class="empty-state"><i class="ri-search-line"></i>Không tìm thấy sản phẩm phù hợp.</div>`;
            return;
        }

        listEl.innerHTML = products.map(p => {
            const price = Number(p.price);
            const priceStr = price.toLocaleString('vi-VN') + '₫';
            const img = p.image ? `/admin/productImages/${p.image}` : '/client/images/no-image.png';
            return `
            <div class="product-item" data-id="${p.id}" data-name="${escHtml(p.name)}" data-price="${price}" data-image="${escHtml(img)}" data-sku="${escHtml(p.sku || '')}">
                <div class="product-image">
                    <img src="${escHtml(img)}" alt="${escHtml(p.name)}" onerror="this.src='/client/images/no-image.png'">
                </div>
                <div class="product-details">
                    <div class="product-name">${escHtml(p.name)}</div>
                    <div class="product-specs">
                        ${p.sku ? `<span class="product-spec">SKU: ${escHtml(p.sku)}</span>` : ''}
                        ${p.brand ? `<span class="product-spec">${escHtml(p.brand.name)}</span>` : ''}
                        <span class="product-spec">${p.stock > 0 ? '✅ Còn hàng' : '❌ Hết hàng'}</span>
                    </div>
                </div>
                <div class="product-price-section">
                    <div class="product-price">${priceStr}</div>
                    <button class="add-to-build-btn" onclick="addToConfig('${p.id}','${escHtml(p.name)}',${price},'${escHtml(img)}','${escHtml(p.sku||'')}')">
                        THÊM VÀO CẤU HÌNH ➤
                    </button>
                </div>
            </div>`;
        }).join('');
    }

    function renderPagination(current, total) {
        const el = document.getElementById('modalPagination');
        if (total <= 1) { el.innerHTML = ''; return; }

        let html = '';
        if (current > 1) html += `<button class="page-btn" onclick="loadProducts(${current-1}, false)">‹</button>`;
        for (let i = 1; i <= total; i++) {
            if (i === current) {
                html += `<button class="page-btn active">${i}</button>`;
            } else if (i === 1 || i === total || Math.abs(i - current) <= 1) {
                html += `<button class="page-btn" onclick="loadProducts(${i}, false)">${i}</button>`;
            } else if (Math.abs(i - current) === 2) {
                html += `<span style="padding:6px 4px;color:#999">…</span>`;
            }
        }
        if (current < total) html += `<button class="page-btn" onclick="loadProducts(${current+1}, false)">›</button>`;
        el.innerHTML = html;
    }

    // =========================================================
    // ADD TO CONFIG
    // =========================================================
    function addToConfig(id, name, price, image, sku) {
        const slot = buildState.currentSlot;
        if (!slot) return;

        buildState.selectedComponents[slot] = { id, name, price, image, sku, qty: 1 };
        renderSlot(slot);
        updateTotal();
        closeModal();
    }

    function renderSlot(slot) {
        const comp = buildState.selectedComponents[slot];
        const item = document.querySelector(`.component-item[data-slot="${slot}"]`);
        if (!item) return;

        const selectedEl = item.querySelector('.component-selected');
        const priceEl = item.querySelector('.build-price');
        const actionsEl = item.querySelector('.component-actions');

        if (!comp) {
            // Reset về trạng thái chưa chọn
            const catSlug = SLOT_CATEGORY[slot] || slot;
            selectedEl.innerHTML = `
                <button class="choose-btn" onclick="openModal('${slot}','${catSlug}')">
                    <span>+</span> ${SLOT_LABELS[slot] || 'Chọn linh kiện'}
                </button>`;
            priceEl.innerHTML = '';
            actionsEl.innerHTML = '';
            return;
        }

        const lineTotal = comp.price * comp.qty;

        selectedEl.innerHTML = `
            <div class="selected-display">
                <img src="${escHtml(comp.image)}" alt="" class="component-image" onerror="this.src='/client/images/no-image.png'">
                <div class="component-info">
                    <div class="comp-name">${escHtml(comp.name)}</div>
                    ${comp.sku ? `<div class="comp-sku">SKU: ${escHtml(comp.sku)}</div>` : ''}
                </div>
            </div>`;

        priceEl.innerHTML = `
            <div class="price-display">${Number(comp.price).toLocaleString('vi-VN')}₫</div>
            <div class="quantity-row">
                <span>x</span>
                <input type="number" class="quantity-input" value="${comp.qty}" min="1" max="99"
                    onchange="updateQty('${slot}', this.value)">
                <span>=</span>
                <span class="line-total" id="lineTotal_${slot}">${lineTotal.toLocaleString('vi-VN')}₫</span>
            </div>`;

        actionsEl.innerHTML = `
            <button class="edit-btn" title="Đổi linh kiện" onclick="openModal('${slot}','${SLOT_CATEGORY[slot]}')">
                <i class="ri-edit-fill"></i>
            </button>
            <button class="delete-btn" title="Xóa" onclick="removeFromConfig('${slot}')">
                <i class="ri-delete-bin-line"></i>
            </button>`;
    }

    function updateQty(slot, val) {
        const qty = Math.max(1, Math.min(99, parseInt(val) || 1));
        if (!buildState.selectedComponents[slot]) return;
        buildState.selectedComponents[slot].qty = qty;
        const lineTotal = buildState.selectedComponents[slot].price * qty;
        const el = document.getElementById(`lineTotal_${slot}`);
        if (el) el.textContent = lineTotal.toLocaleString('vi-VN') + '₫';
        updateTotal();
    }

    function removeFromConfig(slot) {
        if (!confirm('Bạn có muốn xóa linh kiện này khỏi cấu hình?')) return;
        delete buildState.selectedComponents[slot];
        renderSlot(slot);
        updateTotal();
    }

    function updateTotal() {
        let total = 0;
        for (const slot in buildState.selectedComponents) {
            const c = buildState.selectedComponents[slot];
            total += c.price * c.qty;
        }
        document.getElementById('totalPriceBar').textContent =
            `Chi phí dự tính: ${total.toLocaleString('vi-VN')} đ`;
    }

    // =========================================================
    // UTIL
    // =========================================================
    function escHtml(str) {
        if (!str) return '';
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    // =========================================================
    // EVENTS
    // =========================================================
    document.getElementById('componentModal').addEventListener('click', function(e) {
        if (e.target === this) closeModal();
    });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeModal();
    });

    // Tab switching
    document.querySelectorAll('.tab-button').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.tab-button').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
        });
    });

    // Refresh
    document.getElementById('refreshBtn').addEventListener('click', function() {
        if (!confirm('Bạn có muốn làm mới toàn bộ cấu hình?')) return;
        buildState.selectedComponents = {};
        Object.keys(SLOT_LABELS).forEach(slot => renderSlot(slot));
        updateTotal();
    });

    // Search with debounce
    document.getElementById('modalSearch').addEventListener('input', function() {
        clearTimeout(buildState.searchTimer);
        buildState.searchTimer = setTimeout(() => loadProducts(1, false), 350);
    });

    // Sort
    document.getElementById('modalSort').addEventListener('change', function() {
        loadProducts(1, false);
    });

    // Brand filter
    document.getElementById('modalBrand').addEventListener('change', function() {
        loadProducts(1, false);
    });

    // Price filter
    document.getElementById('modalPrice').addEventListener('change', function() {
        loadProducts(1, false);
    });

    // Add to cart button (bulk add)
    document.getElementById('cartBtn').addEventListener('click', async function() {
        const items = Object.values(buildState.selectedComponents);
        if (items.length === 0) {
            alert('Chưa có linh kiện nào trong cấu hình. Vui lòng chọn ít nhất 1 linh kiện.');
            return;
        }

        const payload = {
            items: items.map(c => ({
                product_id: c.id,
                product_qty: c.qty
            }))
        };

        try {
            const res = await fetch('/cart/add-bulk', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            const data = await res.json();
            if (data.success) {
                alert(data.message || 'Đã thêm toàn bộ linh kiện vào giỏ hàng!');
                window.location.href = '/cart';
            } else {
                alert('Có lỗi xảy ra: ' + (data.message || 'Không thể thêm vào giỏ hàng.'));
            }
        } catch (err) {
            console.error('Lỗi khi thêm vào giỏ hàng:', err);
            alert('Lỗi kết nối. Vui lòng thử lại sau.');
        }
    });

    // Print / xem & in
    document.getElementById('printBtn').addEventListener('click', function() {
        const items = Object.values(buildState.selectedComponents);
        if (items.length === 0) { alert('Chưa có linh kiện nào.'); return; }
        let total = 0;
        const rows = Object.keys(buildState.selectedComponents).map(slot => {
            const c = buildState.selectedComponents[slot];
            total += c.price * c.qty;
            return `<tr>
                <td>${SLOT_LABELS[slot] || slot}</td>
                <td>${c.name}</td>
                <td>${c.qty}</td>
                <td style="text-align:right">${(c.price * c.qty).toLocaleString('vi-VN')}₫</td>
            </tr>`;
        }).join('');
        const html = `<html><head><title>Cấu hình PC</title>
        <style>body{font-family:Arial,sans-serif;padding:20px}table{width:100%;border-collapse:collapse}
        th,td{border:1px solid #ddd;padding:8px;font-size:13px}th{background:#f5f5f5}
        .total{font-weight:bold;color:#e74c3c;font-size:16px;text-align:right;margin-top:12px}</style>
        </head><body>
        <h2>Cấu hình PC - PCStore</h2>
        <table><thead><tr><th>Linh kiện</th><th>Sản phẩm</th><th>SL</th><th>Thành tiền</th></tr></thead>
        <tbody>${rows}</tbody></table>
        <p class="total">Tổng chi phí: ${total.toLocaleString('vi-VN')}đ</p>
        </body></html>`;
        const win = window.open('', '_blank');
        win.document.write(html);
        win.document.close();
        win.print();
    });

    // Copy config
    document.getElementById('copyBtn').addEventListener('click', function() {
        const items = Object.entries(buildState.selectedComponents);
        if (items.length === 0) { alert('Chưa có linh kiện nào.'); return; }
        let total = 0;
        const text = items.map(([slot, c]) => {
            total += c.price * c.qty;
            return `${SLOT_LABELS[slot] || slot}: ${c.name} x${c.qty} = ${(c.price * c.qty).toLocaleString('vi-VN')}đ`;
        }).join('\n');
        navigator.clipboard.writeText(text + `\n\nTổng: ${total.toLocaleString('vi-VN')}đ`)
            .then(() => alert('Đã sao chép cấu hình vào clipboard!'))
            .catch(() => alert('Không thể sao chép. Trình duyệt không hỗ trợ.'));
    });
    </script>
    <script src="/assets/js/scripts.js"></script>