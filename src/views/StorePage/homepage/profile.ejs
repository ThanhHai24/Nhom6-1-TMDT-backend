

                <div class="content" style="width: 80%; margin: 0 auto;">
                    <form action="/updateProfile" method="POST" onsubmit="submitAddUser(event);" enctype="multipart/form-data">
                        

                            <!-- Left: Main form -->
                            <div class="">

                                <!-- Thông tin cơ bản -->
                                <div class="card" style="background-color:white">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Thông tin cơ bản</span>
                                            <span style="font-size:12px;color:var(--text-muted)"><span
                                                    style="color:#E24B4A">*</span> Bắt
                                                buộc</span>
                                        </div>

                                        <div class="avatar-upload-row">
                                            <% const avatarUrl=user.avatar || 'UserAvatar.png' ; %>
                                            
                                            <!-- Avatar clickable preview -->
                                            <div class="avatar-wrapper" onclick="document.getElementById('avatarFile').click()" title="Nhấn để đổi ảnh">
                                                <img id="avatarPreview"
                                                    src="/admin/userImages/<%= avatarUrl %>"
                                                    alt="Ảnh đại diện"
                                                    class="avatar-img">
                                                <div class="avatar-overlay">
                                                    <i class="ri-camera-line"></i>
                                                    <span>Đổi ảnh</span>
                                                </div>
                                            </div>

                                            <!-- Upload info -->
                                            <div class="avatar-info">
                                                <div class="avatar-info-title">Ảnh đại diện</div>
                                                <div class="avatar-info-hint">PNG, JPG tối đa 3MB. Nhấn vào ảnh hoặc nút bên dưới để chọn.</div>
                                                <input type="file" name="avatar" id="avatarFile"
                                                    accept=".jpg,.jpeg,.png" style="display:none;"
                                                    onchange="previewAvatar(this)">
                                                <div class="avatar-actions">
                                                    <label class="btn sm" for="avatarFile">
                                                        <i class="ri-upload-2-line"></i> Tải ảnh lên
                                                    </label>
                                                    <button type="button" class="btn sm btn-remove-avatar" onclick="removeAvatar()">
                                                        <i class="ri-delete-bin-line"></i> Xóa ảnh
                                                    </button>
                                                </div>
                                                <div id="avatar-filename" class="avatar-filename"></div>
                                            </div>
                                        </div>

                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label class="form-label">Họ và tên đầy đủ <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="fullName" class="form-input" type="text" id="inp-fullname"
                                                    placeholder="VD: Nguyễn Văn An" oninput="updateAvatar(this.value)"
                                                    value="<%- user.fullName %>">
                                                <input style="display: none;" name="id" type="text"
                                                    value="<%= user.id%>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Tên tài khoản <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="username" class="form-input" type="text" id="inp-username"
                                                    placeholder="VD: nvanan (không dấu, không khoảng trắng)"
                                                    value="<%- user.username %>" disabled>
                                                <span style="font-size:11px;color:var(--text-muted)"
                                                    id="username-hint"></span>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Email <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="email" class="form-input" type="email" id="inp-email"
                                                    placeholder="VD: nvanan@email.com" value="<%- user.email %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Số điện thoại <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="phone" class="form-input" type="tel" id="inp-phone"
                                                    placeholder="VD: 0901 234 567" value="<%- user.phone %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Ngày sinh</label>
                                                <input name="dob" class="form-input" type="date" id="inp-dob"
                                                    value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Giới tính</label>
                                                <select name="gender" class="form-input form-select" id="inp-gender">
                                                    <option value="">-- Chọn giới tính --</option>
                                                    <option value="Male" <% if (user.gender==='Male' ) { %>selected<% }
                                                            %>>Nam
                                                    </option>
                                                    <option value="Female" <% if (user.gender==='Female' ) { %>selected
                                                        <% } %>>
                                                            Nữ
                                                    </option>
                                                    <option value="Other" <% if (user.gender==='Other' ) { %>selected<%
                                                            } %>>
                                                            Khác</option>
                                                </select>
                                            </div>
                                            <div class="form-group full">
                                                <label class="form-label">Số CCCD / CMND</label>
                                                <input name="idCard" class="form-input" type="text" id="inp-cccd"
                                                    placeholder="VD: 001234567890" value="<%- user.idCard %>">
                                            </div>
                                        </div>
                                    </div>

                                <!-- Action buttons -->
                                <div style="display:flex; flex-direction:column; gap:8px; background-color:#2366EF; border-radius:10px;">
                                    <button class="btn primary btn-submit-update" type="submit">Cập nhật</button>
                                </div>

                            </div>
                        

                    </form>
                </div>
    <script>
            function selectStatus(val) {
                ['active', 'inactive'].forEach(s => {
                    const lbl = document.getElementById('status-' + s + '-lbl');
                    if (lbl) lbl.style.borderColor = s === val ? 'var(--accent)' : 'var(--border)';
                });
            }
            const roleDescs = {
                customer: 'Người dùng cuối: tìm kiếm sản phẩm, đặt hàng, thanh toán, theo dõi vận chuyển, đánh giá sản phẩm.',
                store_manager: 'Xem báo cáo doanh thu cửa hàng, quản lý sản phẩm đang bán, chương trình khuyến mãi, quản lý kho.',
                receptionist: 'Tra cứu sản phẩm, người dùng, đơn hàng. Phê duyệt yêu cầu đặt hàng, hỗ trợ khách hàng.',
                warehouse: 'Đóng gói đơn hàng, xác nhận đơn hàng, nhập hàng vào kho, bàn giao cho đơn vị vận chuyển.',
                admin: 'Quyền cao nhất: quản lý toàn bộ hệ thống, người dùng, đơn hàng, kho, khuyến mãi, vận chuyển, báo cáo, sao lưu.'
            };

            function updateRoleDesc() {
                const val = document.getElementById('inp-role').value;
                const el = document.getElementById('role-desc');
                if (val && roleDescs[val]) {
                    el.textContent = roleDescs[val];
                    el.style.display = 'block';
                } else el.style.display = 'none';
            }

            function checkPwStrength() {
                const pw = document.getElementById('inp-pw').value;
                const fill = document.getElementById('pw-strength-fill');
                const label = document.getElementById('pw-strength-label');
                let score = 0;
                if (pw.length >= 8) score++;
                if (/[A-Z]/.test(pw)) score++;
                if (/[0-9]/.test(pw)) score++;
                if (/[^A-Za-z0-9]/.test(pw)) score++;
                const levels = [{
                    w: '0%',
                    c: '#ccc',
                    t: ''
                },
                {
                    w: '25%',
                    c: '#E24B4A',
                    t: 'Rất yếu'
                },
                {
                    w: '50%',
                    c: '#EF9F27',
                    t: 'Yếu'
                },
                {
                    w: '75%',
                    c: '#378ADD',
                    t: 'Trung bình'
                },
                {
                    w: '100%',
                    c: '#1D9E75',
                    t: 'Mạnh'
                },
                ];
                const lv = levels[score] || levels[0];
                fill.style.width = lv.w;
                fill.style.background = lv.c;
                label.textContent = lv.t;
                label.style.color = lv.c;
                checkPwMatch();
            }

            function checkPwMatch() {
                const pw = document.getElementById('inp-pw').value;
                const pw2 = document.getElementById('inp-pw2').value;
                const lbl = document.getElementById('pw-match-label');
                if (!pw2) {
                    lbl.textContent = '';
                    return;
                }
                if (pw === pw2) {
                    lbl.textContent = 'Mật khẩu khớp ✓';
                    lbl.style.color = '#1D9E75';
                } else {
                    lbl.textContent = 'Mật khẩu không khớp';
                    lbl.style.color = '#E24B4A';
                }
            }

            function togglePw(id) {
                const el = document.getElementById(id);
                el.type = el.type === 'password' ? 'text' : 'password';
            }

            // ===== Avatar preview =====
            function previewAvatar(input) {
                const file = input.files[0];
                if (!file) return;

                // Validate size (3MB)
                if (file.size > 3 * 1024 * 1024) {
                    alert('Ảnh quá lớn! Vui lòng chọn ảnh nhỏ hơn 3MB.');
                    input.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                };
                reader.readAsDataURL(file);

                // Show filename
                const nameEl = document.getElementById('avatar-filename');
                if (nameEl) nameEl.textContent = '📎 ' + file.name;
            }

            function removeAvatar() {
                const input = document.getElementById('avatarFile');
                input.value = '';
                // Reset to original avatar from server
                document.getElementById('avatarPreview').src = '/admin/userImages/<%= avatarUrl %>';
                const nameEl = document.getElementById('avatar-filename');
                if (nameEl) nameEl.textContent = '';
            }

            // ===== Form submit =====
            function submitAddUser(event) {
                const errors = [];
                const fullname = document.getElementById('inp-fullname').value.trim();
                const email = document.getElementById('inp-email').value.trim();
                const phone = document.getElementById('inp-phone').value.trim();

                if (!fullname) errors.push('Họ và tên không được để trống');
                if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) errors.push('Email không hợp lệ');
                if (!phone) errors.push('Số điện thoại không được để trống');

                if (errors.length > 0) {
                    event.preventDefault();
                    alert(errors.join('\n'));
                    return;
                }

                const btn = event.submitter;
                if (btn) {
                    btn.textContent = 'Đang lưu...';
                    btn.disabled = true;
                }
            }
        </script>
