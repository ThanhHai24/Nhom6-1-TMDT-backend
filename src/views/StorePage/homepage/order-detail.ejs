
    <%
        const statusLabel = {
            PENDING:    'Chờ xác nhận',
            CONFIRMED:  'Đã xác nhận',
            PROCESSING: 'Đang xử lý',
            SHIPPED:    'Đang giao hàng',
            DELIVERED:  'Đã giao thành công',
            CANCELLED:  'Đã hủy',
            RETURNED:   'Trả hàng'
        }[order.status] || order.status;

        const paymentLabel = {
            COD: 'Thanh toán khi nhận hàng (COD)',
            BANK_TRANSFER: 'Chuyển khoản ngân hàng',
            VNPAY: 'VNPay',
            MOMO: 'MoMo'
        }[order.paymentMethod] || order.paymentMethod;

        const timelineMap = {
            PENDING:    { icon: 'ri-time-line',           label: 'Đặt hàng' },
            CONFIRMED:  { icon: 'ri-checkbox-circle-line',label: 'Xác nhận' },
            PROCESSING: { icon: 'ri-box-3-line',          label: 'Đang xử lý' },
            SHIPPED:    { icon: 'ri-truck-line',          label: 'Đang giao' },
            DELIVERED:  { icon: 'ri-gift-line',           label: 'Giao thành công' },
            CANCELLED:  { icon: 'ri-close-circle-line',   label: 'Đã hủy' },
            RETURNED:   { icon: 'ri-arrow-go-back-line',  label: 'Trả hàng' },
        };
    %>

    <div class="detail-page">

        <!-- Breadcrumb -->
        <div class="breadcrumb">
            <a href="/">Trang chủ</a> &rsaquo;
            <a href="/orders">Đơn hàng của tôi</a> &rsaquo;

        </div>

        <!-- Title bar -->
        <div class="page-titlebar">
            <div class="page-title-left">
                <h3>Đơn hàng <span>#<%= order.code %></span></h3>
                <p>Ngày đặt: <%= new Date(order.createdAt).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></p>
            </div>
            <div class="status-badge <%= order.status %>">
                </i> <%= statusLabel %>
            </div>
        </div>

        <!-- Row 1: Info + Timeline -->
        <div style="display:grid; grid-template-columns: 2fr 1fr; gap:20px;">

            <!-- Order Info -->
            <div class="card">
                <div class="card-head"><i class="ri-file-list-3-line"></i> Thông tin đơn hàng</div>
                <div class="card-body">
                    <div class="info-grid">
                        <div class="info-item">
                            <label>Mã đơn hàng</label>
                            <span>#<%= order.code %></span>
                        </div>
                        <div class="info-item">
                            <label>Trạng thái</label>
                            <span class="status-badge <%= order.status %>" style="padding:4px 10px; font-size:12px;">
                                <%= statusLabel %>
                            </span>
                        </div>
                        <div class="info-item">
                            <label>Người nhận</label>
                            <span><%= order.customerName %></span>
                        </div>
                        <div class="info-item">
                            <label>Số điện thoại</label>
                            <span><%= order.customerPhone %></span>
                        </div>
                        <div class="info-item" style="grid-column: span 2;">
                            <label>Địa chỉ nhận hàng</label>
                            <span><i class="ri-map-pin-line" style="color:var(--red)"></i> <%= order.shippingAddress %></span>
                        </div>
                        <div class="info-item">
                            <label>Phương thức thanh toán</label>
                            <span><%= paymentLabel %></span>
                        </div>
                        <div class="info-item">
                            <label>Trạng thái thanh toán</label>
                            <span style="color:<%= order.paymentStatus === 'PAID' ? '#155724' : '#856404' %>">
                                <% if (order.paymentStatus === 'PAID') { %>
                                ✔ Đã thanh toán
                                <% } else if (order.paymentStatus === 'FAILED') { %>
                                ✖ Thanh toán thất bại
                                <% } else { %>
                                Chưa thanh toán
                                <% } %>
                            </span>
                        </div>
                        <% if (order.notes) { %>
                        <div class="info-item" style="grid-column: span 2;">
                            <label>Ghi chú</label>
                            <span><%= order.notes %></span>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Status Timeline -->
            <div class="card">
                <div class="card-head"><i class="ri-history-line"></i> Lịch sử trạng thái</div>
                <div class="card-body">
                    <% if (order.statusHistory && order.statusHistory.length > 0) { %>
                    <div class="timeline">
                        <% order.statusHistory.forEach(function(h, idx) { %>
                        <% const isCancelled = h.status === 'CANCELLED'; %>
                        <div class="timeline-item">
                            <div class="tl-line"></div>
                            <div class="tl-dot <%= isCancelled ? 'cancelled' : 'done' %>">
                                <i class="<%= (timelineMap[h.status] || {icon:'ri-circle-line'}).icon %>"></i>
                            </div>
                            <div class="tl-content">
                                <div class="tl-title"><%= (timelineMap[h.status] || {label: h.status}).label %></div>
                                <div class="tl-date">
                                    <%= new Date(h.createdAt).toLocaleDateString('vi-VN', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                                </div>
                                <% if (h.notes) { %>
                                <div class="tl-notes"><%= h.notes %></div>
                                <% } %>
                            </div>
                        </div>
                        <% }); %>
                    </div>
                    <% } else { %>
                    <p style="color:var(--text-muted);font-size:13px;padding:0!important;margin:0!important;">Chưa có lịch sử cập nhật.</p>
                    <% } %>
                </div>
            </div>

        </div>

        <!-- Row 2: Products -->
        <div class="card">
            <div class="card-head"><i class="ri-shopping-bag-line"></i> Sản phẩm trong đơn (<%= order.orderItems.length %>)</div>
            <div class="card-body" style="padding-top:12px;">
                <table class="product-table">
                    <thead>
                        <tr>
                            <th style="width:70px;"></th>
                            <th>Sản phẩm</th>
                            <th style="min-width:80px;">Đơn giá</th>
                            <th style="min-width:60px; text-align:center;">SL</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% order.orderItems.forEach(function(item) { %>
                        <tr>
                            <td>
                                <% if (item.product && item.product.image) { %>
                                <img class="prod-img"
                                     src="/admin/productImages/<%= item.product.image %>"
                                     alt="<%= item.product.name %>">
                                <% } else { %>
                                <div class="prod-img-placeholder"><i class="ri-image-line"></i></div>
                                <% } %>
                            </td>
                            <td>
                                <% if (item.product) { %>
                                <div class="prod-name">
                                    <a href="/product/<%= item.product.slug %>" style="color:inherit;text-decoration:none;">
                                        <%= item.product.name %>
                                    </a>
                                </div>
                                <div class="prod-sub">SKU: <%= item.product.sku %></div>
                                <% } else { %>
                                <div class="prod-name" style="color:var(--text-muted);">Sản phẩm không còn tồn tại</div>
                                <% } %>
                            </td>
                            <td style="font-size:14px;color:var(--text-main);font-weight:600;">
                                <%= Number(item.price).toLocaleString('vi-VN') %>đ
                            </td>
                            <td style="text-align:center;font-size:14px;font-weight:600;">
                                x<%= item.quantity %>
                            </td>
                            <td class="price-cell">
                                <%= Number(item.price * item.quantity).toLocaleString('vi-VN') %>đ
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>

                <!-- Total summary -->
                <div class="total-summary">
                    <div class="total-row">
                        <span class="lbl">Tạm tính</span>
                        <span class="val">
                            <%= Number(order.totalAmount).toLocaleString('vi-VN') %>đ
                        </span>
                    </div>
                    <div class="total-row">
                        <span class="lbl">Phí vận chuyển</span>
                        <span class="val" style="color:<%= order.shippingFee > 0 ? 'inherit' : '#155724' %>">
                            <% if (order.shippingFee > 0) { %>
                            <%= Number(order.shippingFee).toLocaleString('vi-VN') %>đ
                            <% } else { %>
                            Miễn phí
                            <% } %>
                        </span>
                    </div>
                    <div class="total-row grand">
                        <span class="lbl">Tổng cộng</span>
                        <span class="val"><%= Number(order.totalAmount + order.shippingFee).toLocaleString('vi-VN') %>đ</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action bar -->
        <div class="action-bar">
            <a href="/orders" class="btn btn-back"><i class="ri-arrow-left-line"></i> Quay lại</a>
            <% if (order.status === 'PENDING') { %>
            <button class="btn btn-cancel" id="btn-cancel-order" onclick="openCancelModal()">
                <i class="ri-close-circle-line"></i> Hủy đơn hàng
            </button>
            <% } %>
        </div>

    </div><!-- /.detail-page -->

    <!-- ===== CANCEL CONFIRM MODAL ===== -->
    <div class="modal-overlay" id="cancelModal">
        <div class="modal-box">
            <div class="modal-icon">⚠️</div>
            <div class="modal-title">Xác nhận hủy đơn hàng?</div>
            <div class="modal-desc">
                Bạn có chắc muốn hủy đơn hàng <br>
                <strong>#<%= order.code %></strong>?<br>
                Hành động này <strong>không thể hoàn tác</strong>.
            </div>
            <div class="modal-actions">
                <button class="btn-modal-no" onclick="closeCancelModal()">Không, giữ lại</button>
                <button class="btn-modal-yes" id="btn-confirm-cancel" onclick="confirmCancel()">Có, hủy đơn</button>
            </div>
        </div>
    </div>

    <!-- ===== TOAST ===== -->
    <div class="toast" id="toast"></div>

    <script>
        // ===== Modal =====
        function openCancelModal()  { document.getElementById('cancelModal').classList.add('open'); }
        function closeCancelModal() { document.getElementById('cancelModal').classList.remove('open'); }

        // Close modal when clicking overlay
        document.getElementById('cancelModal').addEventListener('click', function(e) {
            if (e.target === this) closeCancelModal();
        });

        // ===== Toast =====
        function showToast(msg, type = 'success') {
            const t = document.getElementById('toast');
            t.textContent = (type === 'success' ? '✔ ' : '✖ ') + msg;
            t.className = 'toast show ' + type;
            setTimeout(() => { t.className = 'toast'; }, 3500);
        }

        // ===== Cancel order =====
        async function confirmCancel() {
            const yesBtn = document.getElementById('btn-confirm-cancel');
            yesBtn.disabled = true;
            yesBtn.textContent = 'Đang hủy...';

            try {
                const res = await fetch('/orders/<%= order.code %>/cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await res.json();
                closeCancelModal();

                if (data.success) {
                    showToast('Đơn hàng đã được hủy thành công!', 'success');
                    // Disable cancel button and update badge after short delay
                    setTimeout(() => { location.reload(); }, 1500);
                } else {
                    showToast(data.message || 'Không thể hủy đơn hàng.', 'error');
                    yesBtn.disabled = false;
                    yesBtn.textContent = 'Có, hủy đơn';
                }
            } catch (err) {
                closeCancelModal();
                showToast('Lỗi kết nối. Vui lòng thử lại.', 'error');
                yesBtn.disabled = false;
                yesBtn.textContent = 'Có, hủy đơn';
            }
        }
    </script>

