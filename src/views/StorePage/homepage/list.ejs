

    <div class="list-wrapper">

        <!-- ===== SIDEBAR FILTER ===== -->
        <aside class="filter-sidebar">
            <h3><i class="bi bi-sliders"></i> BỘ LỌC</h3>

            <form id="filterForm" method="GET" action="">

                <!-- Sắp xếp -->
                <div class="filter-group">
                    <div class="filter-group-title">Sắp xếp</div>
                    <select name="sort" class="sort-select" id="sortSelect">
                        <option value=""      <%= !sort || sort===''       ? 'selected':'' %>>Mặc định</option>
                        <option value="price_asc"  <%= sort==='price_asc'  ? 'selected':'' %>>Giá: Thấp → Cao</option>
                        <option value="price_desc" <%= sort==='price_desc' ? 'selected':'' %>>Giá: Cao → Thấp</option>
                        <option value="newest"     <%= sort==='newest'     ? 'selected':'' %>>Mới nhất</option>
                        <option value="hot"        <%= sort==='hot'        ? 'selected':'' %>>Bán chạy</option>
                    </select>
                </div>

                <!-- Khoảng giá -->
                <div class="filter-group">
                    <div class="filter-group-title">Khoảng giá (VNĐ)</div>
                    <div class="price-inputs">
                        <input type="number" name="minPrice" id="minPrice" placeholder="Từ" min="0" value="<%= minPrice || '' %>">
                        <span>—</span>
                        <input type="number" name="maxPrice" id="maxPrice" placeholder="Đến" min="0" value="<%= maxPrice || '' %>">
                    </div>
                    <!-- Quick price ranges -->
                    <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;">
                        <% const ranges = [
                            {label:'Dưới 5tr', min:0, max:5000000},
                            {label:'5-15tr', min:5000000, max:15000000},
                            {label:'15-30tr', min:15000000, max:30000000},
                            {label:'Trên 30tr', min:30000000, max:''},
                        ]; %>
                        <% ranges.forEach(function(r){ %>
                        <button type="button" class="quick-range-btn"
                            data-min="<%= r.min %>" data-max="<%= r.max %>"
                            style="font-size:11px;padding:3px 8px;border:1px solid #ddd;border-radius:20px;background:#f9f9f9;cursor:pointer;transition:all .15s;"
                            onmouseover="this.style.borderColor='#e53935';this.style.color='#e53935'"
                            onmouseout="this.style.borderColor='#ddd';this.style.color='#444'">
                            <%= r.label %>
                        </button>
                        <% }); %>
                    </div>
                </div>

                <!-- Thương hiệu -->
                <% if (typeof brands !== 'undefined' && brands.length > 0) { %>
                <div class="filter-group">
                    <div class="filter-group-title">Thương hiệu</div>
                    <div class="filter-check-list">
                        <% brands.forEach(function(brand){ %>
                        <label class="filter-check-item">
                            <input type="checkbox" name="brandId" value="<%= brand.id %>"
                                <%= (selectedBrands && selectedBrands.includes(String(brand.id))) ? 'checked' : '' %>>
                            <%= brand.name %>
                        </label>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <!-- Tình trạng -->
                <div class="filter-group">
                    <div class="filter-group-title">Tình trạng</div>
                    <div class="filter-check-list">
                        <label class="filter-check-item">
                            <input type="checkbox" name="isNew" value="1" <%= isNew ? 'checked' : '' %>>
                            Hàng mới
                        </label>
                        <label class="filter-check-item">
                            <input type="checkbox" name="isHot" value="1" <%= isHot ? 'checked' : '' %>>
                            Bán chạy (Hot)
                        </label>
                        <label class="filter-check-item">
                            <input type="checkbox" name="inStock" value="1" <%= inStock ? 'checked' : '' %>>
                            Còn hàng
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn-apply-filter"><i class="bi bi-funnel-fill"></i> Áp dụng</button>
                <button type="button" class="btn-reset-filter" onclick="resetFilter()"><i class="bi bi-x-circle"></i> Xoá bộ lọc</button>
            </form>
        </aside>

        <!-- ===== MAIN CONTENT ===== -->
        <div class="list-main">
            <!-- Breadcrumb -->
            <div class="breadcrumb">
                <a href="/">Trang chủ</a> &rsaquo;
                <span><%= categoryName %></span>
            </div>

            <!-- Top bar -->
            <div class="list-topbar">
                <h1><%= categoryName %></h1>
                <div class="result-count">Hiển thị <strong><%= products.length %></strong> sản phẩm</div>
            </div>

            <!-- Product Grid -->
            <% if (products && products.length > 0) { %>
            <div class="product-grid" id="productGrid">
                <% products.forEach(function(p){ %>
                <a href="/product/<%= p.slug%>" style="text-decoration: none; color: inherit; flex-shrink: 0; display: block;">
                    <div class="product-card">
                        <% if (p.isHot) { %><span class="bestseller-label">Hot</span><% } %>
                        <% if (p.isNew) { %><span class="product-badge new">Mới</span><% } %>
                        <div class="product-image">
                            <img src="admin/productImages/<%=p.image %>" alt="PC Gaming">
                        </div>
                        <h3 class="product-title"><%=p.name%></h3>
                        <% if (p.originalPrice && p.originalPrice > p.price) { %>
                        <div class="product-price"><%= p.price.toLocaleString('vi-VN')%>đ

                            <span class="price"><%= p.originalPrice.toLocaleString('vi-VN')%>đ</span>

                        </div>
                        <% } else { %>
                        <div style="font-size: 22px; color: #e61e1e;" class="price">
                            <span class="price"><%= p.price.toLocaleString('vi-VN')%>đ</span>
                        </div>
                        <% } %>
                        <div class="product-stats">
                            <%if(p.stock <= 0){%>
                            <span style="color: red;">Hết hàng</span>
                            <%}else{%>
                            <span style="color: green;"><i class="bi bi-check-circle-fill"></i> Còn hàng</span>
                            <%}%>
                        </div>
                    </div>
                </a>
                <% }); %>
            </div>
            <% } else { %>
            <div class="empty-state">
                <i class="bi bi-search"></i>
                <p>Không tìm thấy sản phẩm phù hợp.<br>Hãy thử thay đổi bộ lọc!</p>
            </div>
            <% } %>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                <button class="page-btn" onclick="goToPage(<%= currentPage - 1 %>)"><i class="bi bi-chevron-left"></i></button>
                <% } %>
                <% for (let i = 1; i <= totalPages; i++) { %>
                <button class="page-btn <%= currentPage === i ? 'active' : '' %>" onclick="goToPage(<%= i %>)"><%= i %></button>
                <% } %>
                <% if (currentPage < totalPages) { %>
                <button class="page-btn" onclick="goToPage(<%= currentPage + 1 %>)"><i class="bi bi-chevron-right"></i></button>
                <% } %>
            </div>
            <% } %>
        </div>
    </div>

    <script>
        // Quick price range buttons
        document.querySelectorAll('.quick-range-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('minPrice').value = this.dataset.min || '';
                document.getElementById('maxPrice').value = this.dataset.max || '';
            });
        });

        // Reset filter
        function resetFilter() {
            window.location.href = window.location.pathname;
        }

        // Pagination with current filters preserved
        function goToPage(page) {
            const params = new URLSearchParams(window.location.search);
            params.set('page', page);
            window.location.href = window.location.pathname + '?' + params.toString();
        }
    </script>
