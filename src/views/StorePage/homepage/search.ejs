    <div class="list-wrapper">

        <!-- ===== SIDEBAR FILTER ===== -->
        <aside class="filter-sidebar">
            <h3><i class="bi bi-sliders"></i> BỘ LỌC</h3>

            <%
                /* Giữ searchTerm khi áp dụng filter */
                const filterAction = '/search';
            %>
            <form id="filterForm" method="GET" action="<%= filterAction %>">
                <!-- Ẩn searchTerm để giữ nguyên từ khóa -->
                <input type="hidden" name="searchTerm" value="<%= searchTerm %>">

                <!-- Sắp xếp -->
                <div class="filter-group">
                    <div class="filter-group-title">Sắp xếp</div>
                    <select name="sort" class="sort-select" id="sortSelect">
                        <option value=""           <%= !sort || sort===''        ? 'selected':'' %>>Mặc định</option>
                        <option value="price_asc"  <%= sort==='price_asc'  ? 'selected':'' %>>Giá: Thấp → Cao</option>
                        <option value="price_desc" <%= sort==='price_desc' ? 'selected':'' %>>Giá: Cao → Thấp</option>
                        <option value="newest"     <%= sort==='newest'     ? 'selected':'' %>>Mới nhất</option>
                    </select>
                </div>

                <!-- Khoảng giá -->
                <div class="filter-group">
                    <div class="filter-group-title">Khoảng giá (VNĐ)</div>
                    <div class="price-inputs">
                        <input type="number" name="minPrice" id="minPrice" placeholder="Từ" min="0" value="<%= minPrice || '' %>">
                        <span>—</span>
                        <input type="number" name="maxPrice" id="maxPrice" placeholder="Đến" min="0" value="<%= maxPrice || '' %>">
                    </div>
                    <div style="display:flex;flex-wrap:wrap;gap:5px;margin-top:8px;">
                        <% const ranges = [
                            {label:'Dưới 5tr', min:0, max:5000000},
                            {label:'5-15tr', min:5000000, max:15000000},
                            {label:'15-30tr', min:15000000, max:30000000},
                            {label:'Trên 30tr', min:30000000, max:''},
                        ]; %>
                        <% ranges.forEach(function(r){ %>
                        <button type="button" class="quick-range-btn"
                            data-min="<%= r.min %>" data-max="<%= r.max %>">
                            <%= r.label %>
                        </button>
                        <% }); %>
                    </div>
                </div>

                <!-- Thương hiệu -->
                <% if (typeof brands !== 'undefined' && brands && brands.length > 0) { %>
                <div class="filter-group">
                    <div class="filter-group-title">Thương hiệu</div>
                    <div class="filter-check-list">
                        <% brands.forEach(function(brand){ %>
                        <label class="filter-check-item">
                            <input type="checkbox" name="brandId" value="<%= brand.id %>"
                                <%= (selectedBrands && selectedBrands.includes(String(brand.id))) ? 'checked' : '' %>>
                            <%= brand.name %>
                        </label>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <!-- Tình trạng -->
                <div class="filter-group">
                    <div class="filter-group-title">Tình trạng</div>
                    <div class="filter-check-list">
                        <label class="filter-check-item">
                            <input type="checkbox" name="isNew" value="1" <%= isNew ? 'checked' : '' %>>
                            Hàng mới
                        </label>
                        <label class="filter-check-item">
                            <input type="checkbox" name="isHot" value="1" <%= isHot ? 'checked' : '' %>>
                            Bán chạy (Hot)
                        </label>
                        <label class="filter-check-item">
                            <input type="checkbox" name="inStock" value="1" <%= inStock ? 'checked' : '' %>>
                            Còn hàng
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn-apply-filter"><i class="bi bi-funnel-fill"></i> Áp dụng</button>
                <button type="button" class="btn-reset-filter" id="btnResetFilter"><i class="bi bi-x-circle"></i> Xoá bộ lọc</button>
            </form>
        </aside>

        <!-- ===== MAIN CONTENT ===== -->
        <div class="list-main">

            <!-- Breadcrumb -->
            <div class="breadcrumb">
                <a href="/">Trang chủ</a> &rsaquo;
                <span>Tìm kiếm "<%= searchTerm %>"</span>
            </div>

            <!-- Search hero -->
            <div class="search-hero">
                <div class="search-hero-text">
                    <h1>Kết quả cho: <em>"<%= searchTerm %>"</em></h1>
                    <p>Tìm thấy <strong style="color:#ff6b6b;"><%= total %></strong> sản phẩm phù hợp</p>
                </div>
            </div>

            <!-- Top bar -->
            <div class="list-topbar">
                <div class="result-count">
                    Hiển thị <strong><%= products.length %></strong> / <strong><%= total %></strong> sản phẩm
                    <% if (sort === 'price_asc') { %> · <span>Giá tăng dần</span>
                    <% } else if (sort === 'price_desc') { %> · <span>Giá giảm dần</span>
                    <% } else if (sort === 'newest') { %> · <span>Mới nhất</span>
                    <% } %>
                </div>
            </div>

            <!-- Product Grid -->
            <% if (products && products.length > 0) { %>
            <div class="product-grid" id="productGrid">
                <% products.forEach(function(p){ %>
                <a href="/product/<%= p.slug%>" style="text-decoration: none; color: inherit; flex-shrink: 0; display: block;">
                    <div class="product-card">
                        <% if (p.isHot) { %><span class="bestseller-label">Hot</span><% } %>
                        <% if (p.isNew) { %><span class="product-badge new">Mới</span><% } %>
                        <div class="product-image">
                            <img src="admin/productImages/<%=p.image %>" alt="PC Gaming">
                        </div>
                        <h3 class="product-title"><%=p.name%></h3>
                        <% if (p.originalPrice && p.originalPrice > p.price) { %>
                        <div class="product-price"><%= p.price.toLocaleString('vi-VN')%>đ

                            <span class="original-price"><%= p.originalPrice.toLocaleString('vi-VN')%>đ</span>

                        </div>
                        <% } else { %>
                        <div style="font-size: 22px; color: #e61e1e;" class="price">
                            <span class="price"><%= p.price.toLocaleString('vi-VN')%>đ</span>
                        </div>
                        <% } %>
                        <div class="product-stats">
                            <%if(p.stock <= 0){%>
                            <span style="color: red;">Hết hàng</span>
                            <%}else{%>
                            <span style="color: green;"><i class="bi bi-check-circle-fill"></i> Còn hàng</span>
                            <%}%>
                        </div>
                    </div>
                </a>
                <% }); %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
            <div class="pagination">
                <% if (currentPage > 1) { %>
                <button class="page-btn" onclick="goToPage(<%= currentPage - 1 %>)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <% } %>

                <%
                    const delta = 2;
                    const left = Math.max(1, currentPage - delta);
                    const right = Math.min(totalPages, currentPage + delta);
                %>
                <% if (left > 1) { %>
                    <button class="page-btn" onclick="goToPage(1)">1</button>
                    <% if (left > 2) { %><span style="padding:0 4px;color:#aaa">…</span><% } %>
                <% } %>
                <% for (let i = left; i <= right; i++) { %>
                <button class="page-btn <%= currentPage === i ? 'active' : '' %>" onclick="goToPage(<%= i %>)">
                    <%= i %>
                </button>
                <% } %>
                <% if (right < totalPages) { %>
                    <% if (right < totalPages - 1) { %><span style="padding:0 4px;color:#aaa">…</span><% } %>
                    <button class="page-btn" onclick="goToPage(<%= totalPages %>)"><%= totalPages %></button>
                <% } %>

                <% if (currentPage < totalPages) { %>
                <button class="page-btn" onclick="goToPage(<%= currentPage + 1 %>)">
                    <i class="bi bi-chevron-right"></i>
                </button>
                <% } %>
            </div>
            <% } %>

            <% } else { %>
            <!-- Empty state -->
            <div class="empty-state">
                <i class="bi bi-search"></i>
                <% if (searchTerm) { %>
                    <p>Không tìm thấy sản phẩm nào cho "<strong><%= searchTerm %></strong>".<br>
                    Hãy thử từ khóa khác hoặc xoá bộ lọc.</p>
                <% } else { %>
                    <p>Nhập từ khóa vào ô tìm kiếm phía trên để bắt đầu.</p>
                <% } %>
                <a href="/">← Về trang chủ</a>
            </div>
            <% } %>
        </div>
    </div>

   
    <script>
        // Quick price range buttons
        document.querySelectorAll('.quick-range-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.getElementById('minPrice').value = this.dataset.min || '';
                document.getElementById('maxPrice').value = this.dataset.max || '';
            });
        });

        // Reset filter — keep searchTerm
        document.getElementById('btnResetFilter').addEventListener('click', function() {
            const term = '<%= searchTerm %>';
            window.location.href = '/search' + (term ? '?searchTerm=' + encodeURIComponent(term) : '');
        });

        // Pagination with all current filters preserved
        function goToPage(page) {
            const params = new URLSearchParams(window.location.search);
            params.set('page', page);
            window.location.href = '/search?' + params.toString();
        }

        // Auto-submit sort on change
        document.getElementById('sortSelect').addEventListener('change', function() {
            document.getElementById('filterForm').submit();
        });
    </script>
