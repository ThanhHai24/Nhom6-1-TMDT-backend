<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.5.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.21.1/axios.min.js"></script>
    <title>PCStore - Cửa hàng máy tính</title>
    <link rel="stylesheet" href="../client/css/style.css">
    <style>
        :root {
            --main-bg: url("/client/images/backweb.webp"

                );
            --promotion-bg: url("/client/images/background_offer_detail.png"

                );
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <header>
            <%- include("../layout/header.ejs") %>
        </header>

        <nav class="main-nav">
            <%- include("../layout/navbar.ejs") %>
        </nav>

        <main>
            <div class="container">
                <div class="breadcrumb">
                    <a href="#">Trang chủ</a> &gt; <a href="#">PC GAMING</a>
                </div>
                <div class="product-section">
                    <div class="product-detail-container">
                        <!-- Product Images -->
                        <div class="product-images">
                            <img src="../admin/productImages/<%= product.image%>" alt="MainImage" class="main-image" id="mainImage">
                            <%
    let images = [];

    try {
        images = JSON.parse(product.images || "[]");
    } catch (e) {
        images = [];
    }
%>

<div class="thumbnail-gallery">
    <% if (images.length > 0) { %>
        <% images.forEach((img, index) => { %>
            <img 
                src="/admin/productImages/<%= img %>" 
                class="thumbnail <%= index === 0 ? 'active' : '' %>"
                onclick="changeMainImage(this)">
        <% }) %>
    <% } else { %>
        <img src="/client/images/no-image.png" class="thumbnail active">
    <% } %>
</div>
                        </div>

                        <!-- Product Info -->
                        <div class="product-info">
                            <h1 class="product-title"><%= product.name%></h1>
                            <div class="product-meta">
                                <div class="meta-item">
                                    Mã SP:
                                    <span><%= product.sku%></span>
                                </div>
                                <div class="meta-item">
                                    Đánh giá:
                                    <span></span>
                                </div>
                                <div class="meta-item">
                                    Bình luận:
                                    <span></span>
                                </div>
                                <div class="meta-item">
                                    Lượt xem: view_count
                                    <span></span>
                                </div>
                                <div class="meta-item">
                                    Đã bán: <%= product.sold%>
                                    <span></span>
                                </div>
                            </div>

                            <div class="warranty-info">
                                <span class="warranty-badge">Bảo hành:</span>
                                <span>12t</span>
                                <span style="margin-left: 15px;">|</span>
                                <span style="margin-left: 10px;">Tình trạng:</span>
                                <span class="stock-status">Còn hàng</span>
                            </div>

                            <!-- Price Section -->
                            <div class="price-section">
                                <div class="current-price">10,000,000đ</div>

                                <span class="original-price">10.000.000đ</span>
                                <span class="discount">Tiết kiệm
                                    0đ</span>

                            </div>

                            <!-- Promotion Box -->

                            <div class="promotion-box">
                                <div class="promotion-header">
                                    <div class="promotion-icon"><i class="bi bi-gift-fill"></i></div>
                                    KHUYẾN MÃI
                                </div>
                                <div class="promotion-list" style="color: black">
                                    <div class="promotion-item">Giảm 10% tối đa 500.000đ cho đơn hàng từ 5.000.000đ
                                        (Mã: PROMO10)</div>
                                    <div class="promotion-item">Giảm 15% tối đa 1.000.000đ cho đơn hàng từ 10.000.000đ
                                        (Mã: PROMO15)</div>
                                    <div class="promotion-item">Giảm 20% tối đa 2.000.000đ cho đơn hàng từ 20.000.000đ
                                        (Mã: PROMO20)</div>
                                </div>
                            </div>



                            <!-- Quantity & Actions -->
                            <form action="/cart/add" method="POST" id="addToCartForm">
                                <div class="quantity-section">
                                    <input type="hidden" name="product_id" value="<%= product.id %>">
                                    <span class="quantity-label">Số lượng:</span>
                                    <div class="quantity-control">
                                        <a class="quantity-btn" onclick="changeQuantity(-1)">-</a>
                                        <input type="number" name="product_qty" class="quantity-input" value="1"
                                            id="quantityInput" min="1">
                                        <a class="quantity-btn" onclick="changeQuantity(1)">+</a>
                                    </div>

                                    <button type="button" class="cart-btn" onclick="addToCart(event)">
                                        <i class="ri-shopping-cart-2-line"></i> Thêm vào giỏ hàng
                                    </button>

                                </div>

                                <div class="action-buttons">

                                    <button type="submit" name="buy-now" class="primary-btn">
                                        ĐẶT MUA NGAY
                                        <div style="font-size: 12px; font-weight: normal; margin-top: 3px;">Giao hàng
                                            tận nơi nhanh chóng</div>
                                    </button>

                                    <div class="secondary-actions">
                                        <a class="secondary-btn">
                                            TRẢ GÓP QUA HỖ SƠ
                                            <div style="font-size: 11px; font-weight: normal; margin-top: 3px;">Chỉ từ
                                                xxx.xxx₫/tháng</div>
                                        </a>
                                        <a class="secondary-btn">
                                            TRẢ GÓP QUA THẺ
                                            <div style="font-size: 11px; font-weight: normal; margin-top: 3px;">Chỉ từ
                                                xxx.xxx₫/tháng</div>
                                        </a>
                                    </div>
                                </div>

                            </form>

