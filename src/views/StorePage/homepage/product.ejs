
            <div class="container">
                <div class="breadcrumb">
                    <a href="#">Trang chủ</a> &gt; <a href="#">PC GAMING</a>
                </div>
                <div class="product-section">
                    <div class="product-detail-container">
                        <!-- Product Images -->
                        <div class="product-images">
                            <img src="../admin/productImages/<%= product.image%>" alt="MainImage" class="main-image" id="mainImage">
                            <%
                                let images = [];

                                try {
                                    images = JSON.parse(product.images || "[]");
                                } catch (e) {
                                    images = [];
                                }
                            %>

                            <div class="thumbnail-gallery">
                                <% if (images.length > 0) { %>
                                    <% images.forEach((img, index) => { %>
                                            <img 
                                                src="/admin/productImages/<%= img %>" 
                                                class="thumbnail <%= index === 0 ? 'active' : '' %>"
                                                onclick="changeMainImage(this)">
                                        <% }) %>
                                    <% } else { %>
                                        <img src="/admin/productImages/no-image.png" class="thumbnail active">
                                    <% } %>
                            </div>
                        </div>

                        <!-- Product Info -->
                        <div class="product-info">
                            <h1 class="product-title"><%= product.name%></h1>
                            <div class="product-meta">
                                <div class="meta-item">
                                    Mã SP:
                                    <span><%= product.sku%></span>
                                </div>
                                <div class="meta-item">
                                    Lượt xem:
                                    <span><%= product.viewCount%></span>
                                </div>
                                <div class="meta-item">
                                    Số lượng còn:
                                    <span><%= product.stock%></span>
                                </div>
                            </div>

                            <div class="warranty-info">
                                <span class="warranty-badge">Bảo hành:</span>
                                <span>36 Tháng</span>
                                <span style="margin-left: 15px;">|</span>
                                <span style="margin-left: 10px;">Tình trạng:</span>
                                <% if(product.stock> 0){%>
                                <span class="stock-status">Còn hàng</span>
                                <%} else {%>    
                                <span style="color:#e53935;font-size:13px;font-weight:600;margin-left:8px;" class="stock-status">Hết hàng</span>
                                <%}%>
                            </div>

                            <!-- Price Section -->
                            <div class="price-section">
                                <div class="current-price"><%= product.price.toLocaleString('vi-VN', {style: 'currency', currency: 'VND'});
                                    %></div>

                                <span class="original-price"><%= product.originalPrice%></span>
                                

                            </div>

                            <!-- Promotion Box -->

                            



                            <!-- Quantity & Actions -->
                            <form action="/cart/add" method="POST" id="addToCartForm">
                                <div class="quantity-section">
                                    <input type="hidden" name="product_id" value="<%= product.id %>">
                                    <span class="quantity-label">Số lượng:</span>
                                    <div class="quantity-control">
                                        <a class="quantity-btn" onclick="changeQuantity(-1)">-</a>
                                        <input type="number" name="product_qty" class="quantity-input" value="<%= product.stock > 0 ? 1 : 0 %>"
                                            id="quantityInput" min="1" max="<%= product.stock %>">
                                        <a class="quantity-btn" onclick="changeQuantity(1)">+</a>
                                    </div>
                                    <% if (product.stock <= 0) { %>
                                    <span style="color:#e53935;font-size:13px;font-weight:600;margin-left:8px;">⚠️ Sản phẩm hiện đã hết hàng</span>
                                    <% } else if (product.stock <= 5) { %>
                                    <span style="color:#f57c00;font-size:13px;font-weight:600;margin-left:8px;">⚠️ Chỉ còn <%= product.stock %> sản phẩm!</span>
                                    <% } %>

                                    <button type="button" class="cart-btn" onclick="addToCart(event)" <% if (product.stock <= 0) { %>disabled style="opacity:0.5;cursor:not-allowed;"<% } %>>
                                        <i class="ri-shopping-cart-2-line"></i> Thêm vào giỏ hàng
                                    </button>

                                </div>

                                <div class="action-buttons">

                                    <button type="submit" name="buy-now" class="primary-btn" <% if (product.stock <= 0) { %>disabled style="opacity:0.5;cursor:not-allowed;"<% } %>>
                                        ĐẶT MUA NGAY
                                        <div style="font-size: 12px; font-weight: normal; margin-top: 3px;">Giao hàng
                                            tận nơi nhanh chóng</div>
                                    </button>

                                    <div class="secondary-actions">
                                        <a class="secondary-btn">
                                            TRẢ GÓP QUA HỖ SƠ
                                            <div style="font-size: 11px; font-weight: normal; margin-top: 3px;">Chỉ từ
                                                xxx.xxx₫/tháng</div>
                                        </a>
                                        <a class="secondary-btn">
                                            TRẢ GÓP QUA THẺ
                                            <div style="font-size: 11px; font-weight: normal; margin-top: 3px;">Chỉ từ
                                                xxx.xxx₫/tháng</div>
                                        </a>
                                    </div>
                                </div>

                            </form>

                            <!-- Features -->
                            <div class="features-section">
                                <h2 class="features-title">YÊN TÂM MUA HÀNG</h2>
                                <div class="features-grid">
                                    <div class="feature-item">
                                        <div class="feature-icon"><i class="bi bi-wallet2"></i></div>
                                        <div class="feature-text">
                                            <div class="feature-label">Cam kết giá tốt nhất thị trường.</div>
                                            <div class="feature-desc">Đảm bảo giá cạnh tranh nhất</div>
                                        </div>
                                    </div>
                                    <div class="feature-item">
                                        <div class="feature-icon"><i class="bi bi-patch-check"></i></div>
                                        <div class="feature-text">
                                            <div class="feature-label">Sản phẩm mới 100%.</div>
                                            <div class="feature-desc">Chính hãng, fullbox</div>
                                        </div>
                                    </div>
                                    <div class="feature-item">
                                        <div class="feature-icon"><i class="bi bi-arrow-repeat"></i></div>
                                        <div class="feature-text">
                                            <div class="feature-label">Lỗi 1 đổi 1 ngay lập tức.</div>
                                            <div class="feature-desc">Hỗ trợ nhanh chóng</div>
                                        </div>
                                    </div>
                                    <div class="feature-item">
                                        <div class="feature-icon"><i class="bi bi-ticket-detailed-fill"></i></div>
                                        <div class="feature-text">
                                            <div class="feature-label">Hỗ trợ trả góp - Thủ tục nhanh gọn.</div>
                                            <div class="feature-desc">Duyệt nhanh, lãi suất tốt</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sản phẩm tương tự -->
                <section class="products-section" style="margin-top: 24px;">
                    <div class="section-header">
                        <h2 class="section-title">SẢN PHẨM TƯƠNG TỰ</h2>
                        <div class="filter-options">
                            <% if (product.category) { %>
                            <a href="/<%= product.category.slug %>" class="filter-option">Xem tất cả &rarr;</a>
                            <% } %>
                        </div>
                    </div>

                    <% if (relatedProducts && relatedProducts.length > 0) { %>
                    <div class="product-slider">
                        <button class="slider-btn prev-btn">❮</button>
                        <div class="product-container">
                            <% relatedProducts.forEach(function(rp) { %>
                            <a href="/product/<%= rp.slug %>" style="text-decoration: none; color: inherit; flex-shrink: 0; display: block;">
                                <div class="product-card">
                                    <% if (rp.isHot) { %>
                                    <div class="bestseller-label">Hot</div>
                                    <% } %>
                                    <div class="product-image">
                                        <img src="/admin/productImages/<%= rp.image %>" alt="<%= rp.name %>" loading="lazy">
                                    </div>
                                    <h3 class="product-title"><%= rp.name %></h3>
                                    <div class="product-price">
                                        <%= rp.price.toLocaleString('vi-VN') %>đ
                                        <% if (rp.originalPrice && rp.originalPrice > rp.price) { %>
                                        <span class="original-price"><%= rp.originalPrice.toLocaleString('vi-VN') %>đ</span>
                                        <% } %>
                                    </div>
                                    <div class="product-stats">
                                        <span>⭐ Đã bán: <%= rp.sold || 0 %></span>
                                    </div>
                                </div>
                            </a>
                            <% }); %>
                        </div>
                        <button class="slider-btn next-btn">❯</button>
                    </div>
                    <% } else { %>
                    <p style="color: #888; text-align: center; padding: 20px 0;">Không có sản phẩm tương tự.</p>
                    <% } %>
                </section>


                <section class="info-section">
                    <div class="info-container">                        
                        <% if (product.description && product.description.trim() !== "") { %>
                        <div class="description">
                            <h2 class="description-title">Giới thiệu sản phẩm: <%= product.name %></h2>
                            <div class="description-detail" id="description-content">
                                <%- product.description %>
                            </div>
                            <div style="text-align:center; margin-top: 12px;">
                                <a class="toggle-btn" onclick="toggleSection('description-content', this)">Xem thêm</a>
                            </div>
                            <% } %>

                        </div>
                        

                        <%
                            let specs = [];
                            try {
                                if (product.specifications) {
                                    specs = typeof product.specifications === 'string'
                                        ? JSON.parse(product.specifications)
                                        : product.specifications;
                                }
                            } catch(e) {
                                specs = [];
                            }
                        %>
                        <% if (specs && specs.length > 0) { %>
                        <div class="specs">
                            <h2 class="specs-title">Thông số kỹ thuật</h2>
                            <div class="spec-detail" id="specs-content">
                                <table class="specs-table">
                                    <tbody>
                                        <% specs.forEach(function(spec) { %>
                                        <tr class="spec-row">
                                            <td class="spec-key"><%= spec.key %></td>
                                            <td class="spec-value">
                                                <% if (spec.productRef) { %>
                                                    <a href="/product/<%= spec.productRef.slug %>" class="spec-product-link">
                                                        <i class="bi bi-box-seam"></i>
                                                        <%= spec.productRef.name %>
                                                    </a>
                                                <% } else { %>
                                                    <%= spec.value %>
                                                <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                            <div style="text-align:center; margin-top: 12px;">
                                <a class="toggle-btn" onclick="toggleSection('specs-content', this)">Xem thêm</a>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </section>
            
            </div>

    <!-- ===== CART TOAST NOTIFICATION ===== -->
    <div id="cart-toast" role="alert" aria-live="assertive">
        <span class="toast-icon" id="toast-icon">✅</span>
        <div class="toast-body">
            <div class="toast-title" id="toast-title">Thêm vào giỏ hàng thành công!</div>
            <div class="toast-msg" id="toast-msg">Sản phẩm đã được thêm vào giỏ hàng của bạn.</div>
        </div>
        <button class="toast-close" onclick="hideCartToast()" title="Đóng">✕</button>
        <div class="toast-progress" id="toast-progress"></div>
    </div>
    <script>
        // =========================
        // PRODUCT IMAGE SLIDER
        // =========================

        const mainImage = document.getElementById("mainImage");
        const thumbnails = document.querySelectorAll(".thumbnail");

        let currentIndex = 0;

        // Đổi ảnh khi click thumbnail
        function changeMainImage(el) {
            mainImage.src = el.src;

            thumbnails.forEach(img => img.classList.remove("active"));
            el.classList.add("active");

            currentIndex = Array.from(thumbnails).indexOf(el);
        }
        // =========================
        // QUANTITY CONTROL
        // =========================

        const MAX_STOCK = parseInt('<%= product.stock %>') || 0;

        function changeQuantity(amount) {
            const input = document.getElementById("quantityInput");
            let value = parseInt(input.value) || 1;

            value += amount;

            if (value < 1) value = 1;
            if (value > MAX_STOCK) {
                value = MAX_STOCK;
                showCartToast(false, 'Đã đạt giới hạn tồn kho!', `Chỉ còn ${MAX_STOCK} sản phẩm trong kho.`);
            }

            input.value = value;
        }

        // Validate khi người dùng nhập tay
        document.getElementById("quantityInput").addEventListener('change', function() {
            let val = parseInt(this.value) || 1;
            if (val < 1) val = 1;
            if (val > MAX_STOCK) {
                val = MAX_STOCK;
                showCartToast(false, 'Đã đạt giới hạn tồn kho!', `Chỉ còn ${MAX_STOCK} sản phẩm trong kho.`);
            }
            this.value = val;
        });


        // =========================
        // ADD TO CART (AJAX)
        // =========================

        // ===== TOAST NOTIFICATION HELPERS =====
        let toastTimer = null;

        function showCartToast(success, title, msg) {
            const toast    = document.getElementById('cart-toast');
            const iconEl   = document.getElementById('toast-icon');
            const titleEl  = document.getElementById('toast-title');
            const msgEl    = document.getElementById('toast-msg');
            const progress = document.getElementById('toast-progress');

            // Reset trạng thái cũ
            toast.classList.remove('show', 'error');
            progress.style.animation = 'none';
            void progress.offsetWidth; // trigger reflow để reset animation

            iconEl.textContent  = success ? '✅' : '❌';
            titleEl.textContent = title;
            msgEl.textContent   = msg;
            if (!success) toast.classList.add('error');

            // Hiện toast
            requestAnimationFrame(() => {
                toast.classList.add('show');
            });

            // Tự ẩn sau 3 giây
            clearTimeout(toastTimer);
            toastTimer = setTimeout(hideCartToast, 3000);
        }

        function hideCartToast() {
            const toast = document.getElementById('cart-toast');
            toast.classList.remove('show');
            clearTimeout(toastTimer);
        }

        // ===== ADD TO CART (AJAX) =====
        async function addToCart(e) {
            e.preventDefault();

            const form = document.getElementById("addToCartForm");
            const formData = new FormData(form);
            const data = Object.fromEntries(formData.entries());

            try {
                const res = await axios.post("/cart/add", data);

                if (res.data && res.data.cartCount) {
                    const badge = document.querySelector('.cart-count');
                    if (badge) badge.textContent = res.data.cartCount;
                }

                const qty = data.product_qty || 1;
                showCartToast(true, 'Thêm vào giỏ hàng thành công!', `Đã thêm ${qty} sản phẩm vào giỏ hàng.`);
            } catch (err) {
                console.error(err);
                showCartToast(false, 'Thêm giỏ hàng thất bại!', 'Vui lòng thử lại hoặc kiểm tra kết nối.');
            }
        }


        // =========================
        // TOGGLE DESCRIPTION / SPECS
        // =========================

        function toggleSection(id, btn) {
            const el = document.getElementById(id);

            if (el.classList.contains("expanded")) {
                el.classList.remove("expanded");
                btn.innerText = "Xem thêm";
            } else {
                el.classList.add("expanded");
                btn.innerText = "Thu gọn";
            }
        }

        // =============================================
        // RELATED PRODUCTS SLIDER
        // =============================================
        (function () {
            const sliders = document.querySelectorAll('.product-slider');
            sliders.forEach(function (slider) {
                const container = slider.querySelector('.product-container');
                const prevBtn   = slider.querySelector('.prev-btn');
                const nextBtn   = slider.querySelector('.next-btn');
                if (!container || !prevBtn || !nextBtn) return;

                function getScrollAmount() {
                    const card = container.querySelector('.product-card, a');
                    if (!card) return 220;
                    const gap = parseFloat(getComputedStyle(container).gap) || 10;
                    return card.offsetWidth + gap;
                }

                nextBtn.addEventListener('click', function () {
                    container.scrollBy({ left: getScrollAmount() * 2, behavior: 'smooth' });
                });
                prevBtn.addEventListener('click', function () {
                    container.scrollBy({ left: -getScrollAmount() * 2, behavior: 'smooth' });
                });

                function updateBtns() {
                    prevBtn.style.opacity = container.scrollLeft <= 1 ? '0.35' : '1';
                    nextBtn.style.opacity =
                        container.scrollLeft + container.clientWidth >= container.scrollWidth - 2
                        ? '0.35' : '1';
                }
                container.addEventListener('scroll', updateBtns);
                updateBtns();
            });
        })();

    </script>
