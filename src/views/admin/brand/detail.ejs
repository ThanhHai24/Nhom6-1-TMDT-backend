<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Quản Trị - Thêm thương hiệu</title>
    <link rel="stylesheet" href="../css/style.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
</head>

<body>

    <!-- SIDEBAR -->
    <%- include('../layout/sidebar') -%>

        <!-- MAIN -->
        <main class="main">
            <!-- HEADER -->
            <%- include('../layout/header') -%>

                <div class="content">

                    <!-- ADD BRAND PAGE -->
                    <div class="page active" id="page-add-brand">
                        <div class="page-header">
                            <div>
                                <h2>Chi tiết thương hiệu</h2>
                                <div class="breadcrumb">Hệ quản trị → <a href="/admin/brands" style="color:var(--accent); text-decoration: none;">Quản lý thương hiệu</a> → Chi tiết
                                </div>
                            </div>
                            <a href="/admin/brands"><button class="btn">← Quay lại</button></a>
                        </div>

                        <form action="/admin/brands/handleupdate" method="POST" onsubmit="submitAddBrand(event);">
                            <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

                                <!-- Left: Main form -->
                                <div style="display:flex;flex-direction:column;gap:16px;">

                                    <!-- Thông tin cơ bản -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Thông tin thương hiệu</span>
                                            <span style="font-size:12px;color:var(--text-muted)"><span
                                                    style="color:#E24B4A">*</span> Bắt
                                                buộc</span>
                                        </div>

                                        <div class="form-grid">
                                            <div class="form-group full">
                                                <label class="form-label">Tên thương hiệu <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="name" class="form-input" type="text" id="inp-name"
                                                    placeholder="VD: ASUS, MSI, GIGABYTE..." value="<%= brand.name %>">
                                                <input type="hidden" name="id" value="<%= brand.id %>">
                                            </div>
                                            <div class="form-group full">
                                                <label class="form-label">Mô tả</label>
                                                <textarea name="description" class="form-input form-textarea" id="inp-desc"
                                                    placeholder="Mô tả chi tiết về thương hiệu..."
                                                    style="width:100%;resize:vertical;min-height:120px;"><%= brand.description %></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Right: Status -->
                                <div style="display:flex;flex-direction:column;gap:16px;">

                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:16px;"><span
                                                class="card-title">Trạng thái</span>
                                        </div>
                                        <div style="display:flex;flex-direction:column;gap:8px;">
                                            <label
                                                style="display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--accent);border-radius:8px;cursor:pointer;"
                                                id="status-active-lbl">
                                                <input type="radio" name="status" value="active" <% if
                                                    (brand.status==='ACTIVE' ) { %>checked<% } %>
                                                    onchange="selectStatus('active')"
                                                    style="accent-color:var(--accent);">
                                                    <div>
                                                        <div style="font-size:13px;font-weight:500;">Hoạt động</div>
                                                        <div style="font-size:11px;color:var(--text-muted);">Thương hiệu được kích hoạt ngay</div>
                                                    </div>
                                            </label>
                                            <label
                                                style="display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--border);border-radius:8px;cursor:pointer;"
                                                id="status-inactive-lbl">
                                                <input type="radio" name="status" value="inactive" <% if
                                                    (brand.status==='INACTIVE' ) { %>checked<% } %>
                                                    onchange="selectStatus('inactive')"
                                                    style="accent-color:var(--accent);">
                                                <div>
                                                    <div style="font-size:13px;font-weight:500;">Bị Khóa</div>
                                                    <div style="font-size:11px;color:var(--text-muted);">Thương hiệu bị ẩn / khóa</div>
                                                </div>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Action buttons -->
                                    <div style="display:flex;flex-direction:column;gap:8px;">
                                        <button class="btn primary" type="submit"
                                            style="width:100%;padding:10px;font-size:14px;">Cập nhật thương hiệu</button>
                                        <a href="/admin/brands"><button class="btn" type="button"
                                                style="width:100%;padding:10px;font-size:14px;">Hủy bỏ</button></a>
                                    </div>

                                    <!-- Validation summary -->
                                    <div id="form-errors"
                                        style="display:none;background:var(--red-50);border:1px solid var(--red-200);border-radius:8px;padding:12px;">
                                        <div
                                            style="font-size:12px;font-weight:500;color:var(--red-600);margin-bottom:6px;">
                                            Vui lòng kiểm tra lại:
                                        </div>
                                        <ul id="error-list"
                                            style="font-size:12px;color:var(--red-600);padding-left:16px;line-height:1.8;">
                                        </ul>
                                    </div>
                                </div>

                            </div>
                        </form>
                    </div>

                </div>
        </main>
        <script>
            function selectStatus(val) {
                ['active', 'inactive'].forEach(s => {
                    const lbl = document.getElementById('status-' + s + '-lbl');
                    if (lbl) lbl.style.borderColor = s === val ? 'var(--accent)' : 'var(--border)';
                });
            }

            function submitAddBrand(event) {
                const errors = [];
                const name = document.getElementById('inp-name').value.trim();

                if (!name) errors.push('Tên thương hiệu không được để trống');

                const errBox = document.getElementById('form-errors');
                const errList = document.getElementById('error-list');
                if (errors.length > 0) {
                    event.preventDefault();
                    errList.innerHTML = errors.map(e => '<li>' + e + '</li>').join('');
                    errBox.style.display = 'block';
                    errBox.scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                    return;
                }
                errBox.style.display = 'none';

                const btn = event.submitter;
                if(btn) {
                    btn.textContent = 'Đang tạo...';
                    setTimeout(() => btn.disabled = true, 50);
                }
            }
        </script>

</body>

</html>
