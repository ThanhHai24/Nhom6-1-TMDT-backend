
            <div class="page active" id="page-reviews">

                <!-- Page header -->
                <div class="page-header">
                    <div>
                        <h2>⭐ Quản lý Đánh giá</h2>
                        <div class="breadcrumb">Hệ quản trị → Đánh giá sản phẩm</div>
                    </div>
                    <a href="/admin/products" class="btn">← Sản phẩm</a>
                </div>

                <!-- Stats cards -->
                <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:20px;">
                    <div class="card" style="text-align:center;padding:20px 12px;background:linear-gradient(135deg,var(--card-bg),rgba(99,102,241,0.05));">
                        <div style="font-size:28px;font-weight:700;color:var(--accent);"><%= totalCount %></div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">Tổng đánh giá</div>
                    </div>
                    <div class="card" style="text-align:center;padding:20px 12px;background:linear-gradient(135deg,var(--card-bg),rgba(234,179,8,0.05));">
                        <div style="font-size:28px;font-weight:700;color:#ca8a04;"><%= stats.avgRating %><span style="font-size:14px;font-weight:400;">/5</span></div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">Điểm trung bình</div>
                    </div>
                    <div class="card" style="text-align:center;padding:20px 12px;background:linear-gradient(135deg,var(--card-bg),rgba(234,179,8,0.05));">
                        <div style="font-size:28px;font-weight:700;color:#ca8a04;"><%= stats.pending %></div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">⏳ Chờ duyệt</div>
                    </div>
                    <div class="card" style="text-align:center;padding:20px 12px;background:linear-gradient(135deg,var(--card-bg),rgba(34,197,94,0.05));">
                        <div style="font-size:28px;font-weight:700;color:#16a34a;"><%= stats.approved %></div>
                        <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">✓ Đã duyệt</div>
                    </div>
                </div>

                <!-- Reviews table card -->
                <div class="card">
                    <div class="card-header" style="margin-bottom:20px;">
                        <span class="card-title">Danh sách đánh giá</span>
                        <span style="font-size:12px;color:var(--text-muted);">
                            Hiển thị <%= (currentPage-1)*limit+1 %>–<%= Math.min(currentPage*limit,totalCount) %> / <%= totalCount %>
                        </span>
                    </div>

                    <% if (reviews.length === 0) { %>
                    <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
                        <div style="font-size:48px;margin-bottom:16px;">💬</div>
                        <div style="font-size:16px;font-weight:600;">Chưa có đánh giá nào</div>
                    </div>
                    <% } else { %>
                    <div style="display:flex;flex-direction:column;gap:12px;">
                        <% reviews.forEach(function(review){ %>
                        <%
                            const statusColor = review.status === 'APPROVED' ? '#16a34a' : review.status === 'REJECTED' ? '#dc2626' : '#ca8a04';
                            const statusBg   = review.status === 'APPROVED' ? 'rgba(34,197,94,0.1)' : review.status === 'REJECTED' ? 'rgba(239,68,68,0.1)' : 'rgba(234,179,8,0.1)';
                            const statusLabel = review.status === 'APPROVED' ? 'Đã duyệt' : review.status === 'REJECTED' ? 'Từ chối' : 'Chờ duyệt';
                        %>
                        <div style="border:1px solid var(--border);border-radius:12px;padding:16px 18px;transition:all 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.1)';this.style.borderColor='var(--accent)'" onmouseout="this.style.boxShadow='none';this.style.borderColor='var(--border)'">
                            <div style="display:flex;align-items:flex-start;gap:14px;flex-wrap:wrap;">

                                <!-- Avatar -->
                                <div style="width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:16px;font-weight:700;flex-shrink:0;">
                                    <%= review.user ? review.user.fullName?.charAt(0)?.toUpperCase() : 'K' %>
                                </div>

                                <!-- Main content -->
                                <div style="flex:1;min-width:200px;">
                                    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:4px;">
                                        <span style="font-size:14px;font-weight:600;"><%= review.user ? review.user.fullName : 'Khách ẩn danh' %></span>
                                        <span style="font-size:11px;color:var(--text-muted);"><%= review.user?.email ?? '' %></span>
                                        <span style="font-size:13px;color:#eab308;letter-spacing:1px;">
                                            <% for(let s=1;s<=5;s++){ %><%= s <= review.rating ? '★' : '☆' %><% } %>
                                        </span>
                                        <span style="font-size:11px;color:var(--text-muted);">
                                            <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString('vi-VN',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'}) : '' %>
                                        </span>
                                    </div>
                                    <!-- Product -->
                                    <% if (review.product) { %>
                                    <a href="/admin/products/<%= review.product.id %>" style="display:inline-flex;align-items:center;gap:6px;font-size:11px;color:var(--accent);text-decoration:none;padding:2px 8px;border:1px solid rgba(99,102,241,0.2);border-radius:20px;margin-bottom:6px;background:rgba(99,102,241,0.05);">
                                        🛍️ <%= review.product.name %>
                                    </a>
                                    <% } %>
                                    <!-- Review title -->
                                    <% if (review.title) { %>
                                    <div style="font-size:13px;font-weight:600;margin-bottom:4px;"><%= review.title %></div>
                                    <% } %>
                                    <!-- Review comment -->
                                    <% if (review.comment) { %>
                                    <div style="font-size:13px;color:var(--text-muted);line-height:1.6;"><%= review.comment %></div>
                                    <% } %>
                                </div>

                                <!-- Status + Actions -->
                                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:8px;flex-shrink:0;">
                                    <span style="padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;background:<%= statusBg %>;color:<%= statusColor %>;"><%= statusLabel %></span>
                                    <div style="display:flex;gap:6px;">
                                        <% if(review.status !== 'APPROVED') { %>
                                        <form action="/admin/reviews/approve/<%= review.id %>" method="post" style="display:inline;">
                                            <button class="btn sm" style="background:rgba(34,197,94,0.12);color:#16a34a;border:1px solid rgba(34,197,94,0.3);" onmouseover="this.style.background='rgba(34,197,94,0.25)'" onmouseout="this.style.background='rgba(34,197,94,0.12)'">✓ Duyệt</button>
                                        </form>
                                        <% } %>
                                        <% if(review.status !== 'REJECTED') { %>
                                        <form action="/admin/reviews/reject/<%= review.id %>" method="post" style="display:inline;">
                                            <button class="btn sm" style="background:rgba(234,179,8,0.12);color:#ca8a04;border:1px solid rgba(234,179,8,0.3);" onmouseover="this.style.background='rgba(234,179,8,0.25)'" onmouseout="this.style.background='rgba(234,179,8,0.12)'">↩ Từ chối</button>
                                        </form>
                                        <% } %>
                                        <form action="/admin/reviews/delete/<%= review.id %>" method="post" style="display:inline;" onsubmit="return confirm('Xóa đánh giá này?')">
                                            <button class="btn sm danger-outline">🗑 Xóa</button>
                                        </form>
                                    </div>
                                </div>

                            </div>
                        </div>
                        <% }); %>
                    </div>

                    <!-- Pagination -->
                    <% if (totalPages > 1) { %>
                    <div class="pagination-wrap" style="margin-top:20px;">
                        <span class="pagination-info">
                            Hiển thị <%= (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, totalCount) %> / <%= totalCount %>
                        </span>
                        <div class="pagination">
                            <% if (currentPage > 1) { %>
                                <a href="?page=<%= currentPage - 1 %>" class="page-btn">&#8592;</a>
                            <% } else { %>
                                <span class="page-btn disabled">&#8592;</span>
                            <% } %>

                            <% let startPage = Math.max(1, currentPage - 2);
                               let endPage   = Math.min(totalPages, currentPage + 2); %>

                            <% if (startPage > 1) { %>
                                <a href="?page=1" class="page-btn">1</a>
                                <% if (startPage > 2) { %><span class="page-ellipsis">…</span><% } %>
                            <% } %>
                            <% for (let p = startPage; p <= endPage; p++) { %>
                                <a href="?page=<%= p %>" class="page-btn <%= p === currentPage ? 'active' : '' %>"><%= p %></a>
                            <% } %>
                            <% if (endPage < totalPages) { %>
                                <% if (endPage < totalPages - 1) { %><span class="page-ellipsis">…</span><% } %>
                                <a href="?page=<%= totalPages %>" class="page-btn"><%= totalPages %></a>
                            <% } %>

                            <% if (currentPage < totalPages) { %>
                                <a href="?page=<%= currentPage + 1 %>" class="page-btn">&#8594;</a>
                            <% } else { %>
                                <span class="page-btn disabled">&#8594;</span>
                            <% } %>
                        </div>
                    </div>
                    <% } %>

                    <% } %>
                </div>

            </div>
        