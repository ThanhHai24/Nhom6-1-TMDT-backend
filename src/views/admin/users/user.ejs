<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Quản Trị - Admin Dashboard</title>
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

    <!-- SIDEBAR -->
    <%- include('../layout/sidebar') -%>

        <!-- MAIN -->
        <main class="main">
            <!-- HEADER -->
            <%- include('../layout/header') -%>

                <div class="content">

                    <!-- USERS PAGE -->
                    <div class="page active" id="page-users">
                        <div class="page-header">
                            <div>
                                <h2>Quản lý người dùng</h2>
                                <div class="breadcrumb">Hệ quản trị → Quản lý người dùng</div>
                            </div>
                            <a href="/admin/users/create"><button class="btn primary">+ Thêm người dùng</button></a>
                        </div>

                        <div class="stat-grid" style="grid-template-columns: repeat(3,1fr);">
                            <div class="stat-card blue">
                                <div class="stat-label">Tổng người dùng</div>
                                <div class="stat-value">12,483</div>
                            </div>
                            <div class="stat-card teal">
                                <div class="stat-label">Đang hoạt động</div>
                                <div class="stat-value">11,204</div>
                            </div>
                            <div class="stat-card red">
                                <div class="stat-label">Bị khóa</div>
                                <div class="stat-value">279</div>
                            </div>
                        </div>

                        <div class="card">
                            <div class="toolbar">
                                <div class="search-box">
                                    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#888"
                                        stroke-width="1.5">
                                        <circle cx="7" cy="7" r="5" />
                                        <path d="M11 11l3 3" />
                                    </svg>
                                    <input type="text" placeholder="Tìm theo tên, email, SĐT, CCCD...">
                                </div>
                                <select class="filter-select">
                                    <option>Tất cả vai trò</option>
                                    <option>Khách hàng</option>
                                    <option>Quản lý cửa hàng</option>
                                    <option>Lễ tân</option>
                                    <option>Nhân viên kho</option>
                                </select>
                                <select class="filter-select">
                                    <option>Tất cả trạng thái</option>
                                    <option>Đang hoạt động</option>
                                    <option>Bị khóa</option>
                                </select>
                                <button class="btn">Bộ lọc</button>
                            </div>
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Người dùng</th>
                                        <th>Vai trò</th>
                                        <th>SĐT</th>
                                        <th>Ngày tạo</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div class="user-avatar" style="background:#378ADD">NA</div>
                                                <div>
                                                    <div class="user-name">Nguyễn Văn An</div>
                                                    <div class="user-email">nvanan@email.com</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge info">Khách hàng</span></td>
                                        <td>0901 234 567</td>
                                        <td>12/01/2025</td>
                                        <td><span class="badge active">Hoạt động</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button class="btn sm">Chi
                                                tiết</button><button class="btn sm danger-outline">Khóa</button></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div class="user-avatar" style="background:#1D9E75">TB</div>
                                                <div>
                                                    <div class="user-name">Trần Thị Bình</div>
                                                    <div class="user-email">ttbinh@shopmail.vn</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge active">Quản lý CH</span></td>
                                        <td>0912 345 678</td>
                                        <td>05/03/2024</td>
                                        <td><span class="badge active">Hoạt động</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button class="btn sm">Chi
                                                tiết</button><button class="btn sm danger-outline">Khóa</button></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div class="user-avatar" style="background:#EF9F27">LC</div>
                                                <div>
                                                    <div class="user-name">Lê Minh Châu</div>
                                                    <div class="user-email">lmchau@shopmail.vn</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge pending">Lễ tân</span></td>
                                        <td>0923 456 789</td>
                                        <td>20/06/2024</td>
                                        <td><span class="badge active">Hoạt động</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button class="btn sm">Chi
                                                tiết</button><button class="btn sm danger-outline">Khóa</button></td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div class="user-avatar" style="background:#A32D2D">PG</div>
                                                <div>
                                                    <div class="user-name">Phạm Hương Giang</div>
                                                    <div class="user-email">phgiang@email.com</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge info">Khách hàng</span></td>
                                        <td>0934 567 890</td>
                                        <td>08/11/2024</td>
                                        <td><span class="badge danger">Bị khóa</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button class="btn sm">Chi
                                                tiết</button><button class="btn sm">Mở khóa</button></td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="pagination">
                                <span>Hiển thị 1–4 / 12,483 người dùng</span>
                                <div class="page-btns">
                                    <div class="page-btn">‹</div>
                                    <div class="page-btn active">1</div>
                                    <div class="page-btn">2</div>
                                    <div class="page-btn">3</div>
                                    <div class="page-btn">…</div>
                                    <div class="page-btn">›</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
        </main>
</body>

</html>