<!-- EDIT BANNER PAGE -->
<div class="page active" id="page-edit-banner">
    <div class="page-header">
        <div>
            <h2>Chi tiết Banner / Slide</h2>
            <div class="breadcrumb">Hệ quản trị → <a href="/admin/banners" style="color:var(--accent); text-decoration: none;">Quản lý Banner</a> → Chi tiết</div>
        </div>
        <a href="/admin/banners"><button class="btn">← Quay lại</button></a>
    </div>

    <form action="/admin/banners/handleupdate" method="POST" enctype="multipart/form-data" onsubmit="submitEditBanner(event);">
        <div style="display:grid; grid-template-columns:1fr 320px; gap:20px; align-items:start;">

            <!-- Left: Main form -->
            <div style="display:flex; flex-direction:column; gap:16px;">
                <div class="card">
                    <div class="card-header" style="margin-bottom:20px;">
                        <span class="card-title">Thông tin chi tiết</span>
                        <span style="font-size:12px; color:var(--text-muted)"><span style="color:#E24B4A">*</span> Bắt buộc</span>
                    </div>

                    <div class="form-grid">
                        <div class="form-group full">
                            <label class="form-label">Tiêu đề (Tùy chọn)</label>
                            <input name="title" class="form-input" type="text" id="inp-title" placeholder="Tiêu đề quảng cáo..." value="<%= banner.title || '' %>">
                            <input type="hidden" name="id" value="<%= banner.id %>">
                        </div>

                        <div class="form-group full">
                            <label class="form-label">Đường dẫn liên kết (Tùy chọn)</label>
                            <input name="link" class="form-input" type="text" id="inp-link" placeholder="Ví dụ: /pc-gaming hoặc https://google.com" value="<%= banner.link || '' %>">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Loại quảng cáo <span style="color:#E24B4A">*</span></label>
                            <select name="type" id="inp-type" class="form-input" onchange="handleTypeChange()" style="width:100%; height:40px; border:1px solid var(--border); border-radius:8px; padding:0 12px; outline:none; background:var(--card-bg);">
                                <option value="SLIDESHOW" <%= banner.type === 'SLIDESHOW' ? 'selected' : '' %>>Slideshow (Bảng chính ở trang chủ)</option>
                                <option value="BOTTOM_BANNER" <%= banner.type === 'BOTTOM_BANNER' ? 'selected' : '' %>>Bottom Banner (2 Banner phía dưới slideshow)</option>
                                <option value="SIDE_BANNER" <%= banner.type === 'SIDE_BANNER' ? 'selected' : '' %>>Side Banner (2 Banner chạy dọc hai bên màn hình)</option>
                            </select>
                        </div>

                        <div class="form-group" id="group-position">
                            <label class="form-label">Vị trí hiển thị <span style="color:#E24B4A">*</span></label>
                            <select name="position" id="inp-position" class="form-input" style="width:100%; height:40px; border:1px solid var(--border); border-radius:8px; padding:0 12px; outline:none; background:var(--card-bg);">
                                <!-- Sẽ được cập nhật động qua JS -->
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Thứ tự hiển thị (Số nhỏ xếp trước)</label>
                            <input name="order" class="form-input" type="number" id="inp-order" value="<%= banner.order %>" min="0">
                        </div>

                        <div class="form-group">
                            <label class="form-label">Hình ảnh hiện tại</label>
                            <div style="margin-bottom: 10px;">
                                <img id="current-image" src="/admin/bannerImages/<%= banner.image %>" alt="Current Banner" style="max-width: 100%; max-height: 150px; border-radius: 4px; border: 1px solid #ddd; display: block;">
                            </div>
                            
                            <label class="form-label">Thay đổi hình ảnh mới (Để trống nếu giữ nguyên)</label>
                            <input name="image" class="form-input" type="file" id="inp-image" accept="image/*" onchange="previewImage(event)" style="padding-top:8px;">
                            <div style="font-size:11px; color:var(--text-muted); margin-top:4px;">Chấp nhận file PNG, JPG, JPEG. Dung lượng tối đa 3MB.</div>
                        </div>

                        <div class="form-group full" id="image-preview-group" style="display:none; margin-top:10px;">
                            <label class="form-label">Xem trước hình ảnh thay đổi</label>
                            <div style="border: 1px solid #ddd; border-radius: 8px; padding: 10px; display: inline-block; background: #fafafa;">
                                <img id="image-preview" src="#" alt="Preview" style="max-width: 100%; max-height: 200px; border-radius: 4px; display: block;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Side actions / Status -->
            <div style="display:flex; flex-direction:column; gap:16px;">
                <div class="card">
                    <div class="card-header" style="margin-bottom:16px;">
                        <span class="card-title">Trạng thái</span>
                    </div>
                    <div style="display:flex; flex-direction:column; gap:8px;">
                        <label style="display:flex; align-items:center; gap:10px; padding:10px; border:1px solid <%= banner.status === 'ACTIVE' ? 'var(--accent)' : 'var(--border)' %>; border-radius:8px; cursor:pointer;" id="status-active-lbl">
                            <input type="radio" name="status" value="ACTIVE" <%= banner.status === 'ACTIVE' ? 'checked' : '' %> onchange="selectStatus('ACTIVE')" style="accent-color:var(--accent);">
                            <div>
                                <div style="font-size:13px; font-weight:500;">Hiển thị</div>
                                <div style="font-size:11px; color:var(--text-muted);">Cho phép hiển thị ngoài Store</div>
                            </div>
                        </label>
                        <label style="display:flex; align-items:center; gap:10px; padding:10px; border:1px solid <%= banner.status === 'INACTIVE' ? 'var(--accent)' : 'var(--border)' %>; border-radius:8px; cursor:pointer;" id="status-inactive-lbl">
                            <input type="radio" name="status" value="INACTIVE" <%= banner.status === 'INACTIVE' ? 'checked' : '' %> onchange="selectStatus('INACTIVE')" style="accent-color:var(--accent);">
                            <div>
                                <div style="font-size:13px; font-weight:500;">Tạm ẩn</div>
                                <div style="font-size:11px; color:var(--text-muted);">Ẩn khỏi Store</div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Action buttons -->
                <div style="display:flex; flex-direction:column; gap:8px;">
                    <button class="btn primary" type="submit" style="width:100%; padding:10px; font-size:14px;">Cập nhật Banner / Slide</button>
                    <a href="/admin/banners" style="text-decoration:none;"><button class="btn" type="button" style="width:100%; padding:10px; font-size:14px;">Hủy bỏ</button></a>
                </div>

                <!-- Validation errors -->
                <div id="form-errors" style="display:none; background:var(--red-50); border:1px solid var(--red-200); border-radius:8px; padding:12px;">
                    <div style="font-size:12px; font-weight:500; color:var(--red-600); margin-bottom:6px;">
                        Vui lòng kiểm tra lại:
                    </div>
                    <ul id="error-list" style="font-size:12px; color:var(--red-600); padding-left:16px; line-height:1.8; margin:0;">
                    </ul>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    // Selected position to restore
    const savedPosition = "<%= banner.position || '' %>";

    // Status box toggle styles
    function selectStatus(val) {
        ['ACTIVE', 'INACTIVE'].forEach(s => {
            const lbl = document.getElementById('status-' + s.toLowerCase() + '-lbl');
            if (lbl) {
                lbl.style.borderColor = s === val ? 'var(--accent)' : 'var(--border)';
            }
        });
    }

    // Dynamic Select lists for position
    function handleTypeChange() {
        const typeSelect = document.getElementById('inp-type');
        const posSelect = document.getElementById('inp-position');
        const posGroup = document.getElementById('group-position');
        const type = typeSelect.value;

        // Clear existing options
        posSelect.innerHTML = '';

        if (type === 'SLIDESHOW') {
            // Slideshow doesn't require specific position
            posGroup.style.display = 'none';
            const opt = document.createElement('option');
            opt.value = '';
            opt.textContent = 'Mặc định';
            posSelect.appendChild(opt);
        } else {
            posGroup.style.display = 'block';

            if (type === 'SIDE_BANNER') {
                const optLeft = document.createElement('option');
                optLeft.value = 'LEFT';
                optLeft.textContent = 'Banner Trái (LEFT)';
                if (savedPosition === 'LEFT') optLeft.selected = true;
                
                const optRight = document.createElement('option');
                optRight.value = 'RIGHT';
                optRight.textContent = 'Banner Phải (RIGHT)';
                if (savedPosition === 'RIGHT') optRight.selected = true;
                
                posSelect.appendChild(optLeft);
                posSelect.appendChild(optRight);
            } else if (type === 'BOTTOM_BANNER') {
                const optBot1 = document.createElement('option');
                optBot1.value = 'BOTTOM_1';
                optBot1.textContent = 'Banner Dưới 1 (BOTTOM_1)';
                if (savedPosition === 'BOTTOM_1') optBot1.selected = true;
                
                const optBot2 = document.createElement('option');
                optBot2.value = 'BOTTOM_2';
                optBot2.textContent = 'Banner Dưới 2 (BOTTOM_2)';
                if (savedPosition === 'BOTTOM_2') optBot2.selected = true;
                
                posSelect.appendChild(optBot1);
                posSelect.appendChild(optBot2);
            }
        }
    }

    // Image preview
    function previewImage(event) {
        const reader = new FileReader();
        reader.onload = function() {
            const output = document.getElementById('image-preview');
            output.src = reader.result;
            document.getElementById('image-preview-group').style.display = 'block';
        };
        reader.readAsDataURL(event.target.files[0]);
    }

    // Form validation
    function submitEditBanner(event) {
        const errors = [];
        const typeSelect = document.getElementById('inp-type');
        const posSelect = document.getElementById('inp-position');

        if (typeSelect.value !== 'SLIDESHOW' && !posSelect.value) {
            errors.push('Vui lòng chọn vị trí hiển thị');
        }

        const errBox = document.getElementById('form-errors');
        const errList = document.getElementById('error-list');
        if (errors.length > 0) {
            event.preventDefault();
            errList.innerHTML = errors.map(e => '<li>' + e + '</li>').join('');
            errBox.style.display = 'block';
            errBox.scrollIntoView({
                behavior: 'smooth',
                block: 'center'
            });
            return;
        }
        errBox.style.display = 'none';

        const btn = event.submitter;
        if (btn) {
            btn.textContent = 'Đang cập nhật...';
            setTimeout(() => btn.disabled = true, 50);
        }
    }

    // Initial load
    document.addEventListener('DOMContentLoaded', function() {
        handleTypeChange();
    });
</script>
