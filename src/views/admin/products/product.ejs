<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Quản Trị - Admin Dashboard</title>
    <link rel="stylesheet" href="css/style.css">
</head>

<body>

    <!-- SIDEBAR -->
    <%- include('../layout/sidebar') -%>

        <!-- MAIN -->
        <main class="main">
            <!-- HEADER -->
            <%- include('../layout/header') -%>

                <div class="content">

                    <!-- PRODUCTS PAGE -->
                    <div class="page active" id="page-products">
                        <div class="page-header">
                            <div>
                                <h2>Danh mục sản phẩm</h2>
                                <div class="breadcrumb">Hệ quản trị → Danh mục sản phẩm</div>
                            </div>
                            <div style="display:flex;gap:8px">
                                <button class="btn">Nhập Excel</button>
                                <button class="btn primary">+ Thêm sản phẩm</button>
                            </div>
                        </div>
                        <div class="card">
                            <div class="toolbar">
                                <div class="search-box"><svg width="14" height="14" viewBox="0 0 16 16" fill="none"
                                        stroke="#888" stroke-width="1.5">
                                        <circle cx="7" cy="7" r="5" />
                                        <path d="M11 11l3 3" />
                                    </svg><input type="text" placeholder="Tìm sản phẩm..."></div>
                                <select class="filter-select">
                                    <option>Tất cả danh mục</option>
                                    <option>Điện thoại</option>
                                    <option>Máy tính xách tay</option>
                                    <option>Tai nghe</option>
                                    <option>Phụ kiện</option>
                                </select>
                                <select class="filter-select">
                                    <option>Tất cả trạng thái</option>
                                    <option>Đang bán</option>
                                    <option>Hết hàng</option>
                                    <option>Ngưng bán</option>
                                </select>
                            </div>
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>SKU</th>
                                        <th>Danh mục</th>
                                        <th>Giá bán</th>
                                        <th>Tồn kho</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div
                                                    style="width:36px;height:36px;background:#E6F1FB;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px">
                                                    📱</div>
                                                <div>
                                                    <div class="user-name">iPhone 15 Pro Max</div>
                                                    <div class="user-email">Apple / 256GB</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="font-family:monospace;font-size:12px">IP15PM-256</td>
                                        <td>Điện thoại</td>
                                        <td>34,990,000 ₫</td>
                                        <td>
                                            <div class="stock-level">
                                                <div class="stock-bar">
                                                    <div class="stock-fill high" style="width:80%"></div>
                                                </div><span class="stock-num">400</span>
                                            </div>
                                        </td>
                                        <td><span class="badge active">Đang bán</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button
                                                class="btn sm">Sửa</button><button
                                                class="btn sm danger-outline">Xóa</button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div
                                                    style="width:36px;height:36px;background:#E1F5EE;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px">
                                                    💻</div>
                                                <div>
                                                    <div class="user-name">MacBook Air M4</div>
                                                    <div class="user-email">Apple / 16GB RAM</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="font-family:monospace;font-size:12px">MBA-M4-16</td>
                                        <td>Máy tính xách tay</td>
                                        <td>28,990,000 ₫</td>
                                        <td>
                                            <div class="stock-level">
                                                <div class="stock-bar">
                                                    <div class="stock-fill mid" style="width:35%"></div>
                                                </div><span class="stock-num">87</span>
                                            </div>
                                        </td>
                                        <td><span class="badge active">Đang bán</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button
                                                class="btn sm">Sửa</button><button
                                                class="btn sm danger-outline">Xóa</button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="user-cell">
                                                <div
                                                    style="width:36px;height:36px;background:#FAEEDA;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px">
                                                    🎧</div>
                                                <div>
                                                    <div class="user-name">AirPods Pro 3</div>
                                                    <div class="user-email">Apple / MagSafe</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="font-family:monospace;font-size:12px">APP3-MCS</td>
                                        <td>Tai nghe</td>
                                        <td>6,490,000 ₫</td>
                                        <td>
                                            <div class="stock-level">
                                                <div class="stock-bar">
                                                    <div class="stock-fill low" style="width:12%"></div>
                                                </div><span class="stock-num">23</span>
                                            </div>
                                        </td>
                                        <td><span class="badge pending">Sắp hết</span></td>
                                        <td style="display:flex;gap:6px;padding-top:10px"><button
                                                class="btn sm">Sửa</button><button
                                                class="btn sm danger-outline">Xóa</button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
        </main>
</body>

</html>