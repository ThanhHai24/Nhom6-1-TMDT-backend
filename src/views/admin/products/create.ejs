                                                    style="color:#E24B4A">*</span> Bắt
                                                buộc</span>
                                        </div>

                                        <div class="form-grid">
                                            <div class="form-group full">
                                                <label class="form-label">Tên sản phẩm <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="name" class="form-input" type="text" id="inp-name"
                                                    placeholder="VD: iPhone 15 Pro Max 256GB">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">SKU / Mã sản phẩm <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="sku" class="form-input" type="text" id="inp-sku"
                                                    placeholder="Mã sản phẩm sẽ được tự động thêm."
                                                    style="font-family:monospace;" disabled>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Danh mục <span
                                                        style="color:#E24B4A">*</span></label>
                                                <select name="category" class="form-input form-select"
                                                    id="inp-category" onchange="updateSpecDropdowns(); filterBrandsByCategory();">
