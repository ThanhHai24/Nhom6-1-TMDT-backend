                                                        <option value="<%= category.id %>" data-name="<%= category.name.toLowerCase() %>" data-slug="<%= category.slug %>">
                                                            <%= category.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Thương hiệu</label>
                                                <select name="brand" class="form-input form-select" id="inp-brand">
