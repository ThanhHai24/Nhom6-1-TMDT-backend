
                    <!-- ADD PRODUCT PAGE -->
                    <div class="page active" id="page-add-product">
                        <div class="page-header">
                            <div>
                                <h2>Chi tiết sản phẩm</h2>
                                <div class="breadcrumb">Hệ quản trị → <span onclick="showPage('products')"
                                        style="cursor:pointer;color:var(--accent)">Danh mục sản phẩm</span> → <%= product?.name %>
                                </div>
                            </div>
                            <a href="/admin/products"><button class="btn">← Quay lại</button></a>
                        </div>

                        <form action="/admin/product/handleupdate" method="POST" onsubmit="submitAddProduct(event);"
                            enctype="multipart/form-data">
                            <div style="display:grid;grid-template-columns:1fr 320px;gap:20px;align-items:start;">

                                <!-- Left: Main form -->
                                <div style="display:flex;flex-direction:column;gap:16px;">

                                    <!-- Thông tin cơ bản -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Thông tin cơ bản</span>
                                            <span style="font-size:12px;color:var(--text-muted)"><span
                                                    style="color:#E24B4A">*</span> Bắt
                                                buộc</span>
                                        </div>

                                        <div class="form-grid">
                                            <div class="form-group full">
                                                <label class="form-label">Tên sản phẩm <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="name" class="form-input" type="text" id="inp-name"
                                                    placeholder="VD: iPhone 15 Pro Max 256GB" value="<%= product?.name %>">
                                                <input type="hidden" name="id" value="<%= product?.id %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">SKU / Mã sản phẩm <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="sku" class="form-input" type="text" id="inp-sku"
                                                    placeholder="Mã sản phẩm sẽ được định sẵn."
                                                    style="font-family:monospace;" disabled value="<%= product?.sku %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Thương hiệu</label>
                                                <select name="brand" class="form-input form-select" id="inp-brand">
                                                    <option value="">-- Chọn Thương hiệu --</option>
                                                    <% brands.forEach( function (brand) { %>
                                                        <option value="<%= brand.id %>" data-id="<%= brand.id %>" <%= String(brand.id) === String(product?.brandId) ? 'selected' : '' %>>
                                                            <%= brand.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                                <div id="brand-loading" style="display:none;font-size:11px;color:var(--text-muted);margin-top:4px;">⏳ Đang tải thương hiệu...</div>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Danh mục <span
                                                        style="color:#E24B4A">*</span></label>
                                                <select name="category" class="form-input form-select"
                                                    id="inp-category" onchange="updateSpecDropdowns(); filterBrandsByCategory();">
                                                    <option value="">-- Chọn danh mục --</option>
                                                    <% categories.forEach( function (category) { %>
                                                        <option value="<%= category.id %>" data-name="<%= category.name.toLowerCase() %>" data-slug="<%= category.slug %>" <%= String(category.id) === String(product?.categoryId) ? 'selected' : '' %>>
                                                            <%= category.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Nhà phân phối</label>
                                                <select name="supplier" class="form-input form-select"
                                                    id="inp-supplier">
                                                    <option value="">-- Chọn nhà phân phối --</option>
                                                    <% suppliers.forEach( function (supplier) { %>
                                                        <option value="<%= supplier.id %>" <%= String(supplier.id) === String(product?.supplierId) ? 'selected' : '' %>>
                                                            <%= supplier.name %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Mô tả ngắn</label>
                                                <input name="shortDescription" class="form-input" type="text"
                                                    id="inp-short-desc"
                                                    placeholder="Mô tả ngắn gọn về sản phẩm, hiển thị trên danh sách" value="<%= product?.shortDescription %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Bảo hành</label>
                                                <select name="warranty" class="form-input form-select" id="inp-warranty">
                                                    <option value="">-- Chọn thời gian bảo hành --</option>
                                                    <option value="6"  <%= product?.warranty == 6  ? 'selected' : '' %>>6 Tháng</option>
                                                    <option value="12" <%= product?.warranty == 12 ? 'selected' : '' %>>12 Tháng</option>
                                                    <option value="24" <%= product?.warranty == 24 ? 'selected' : '' %>>24 Tháng</option>
                                                    <option value="36" <%= product?.warranty == 36 ? 'selected' : '' %>>36 Tháng</option>
                                                    <option value="48" <%= product?.warranty == 48 ? 'selected' : '' %>>48 Tháng</option>
                                                    <option value="60" <%= product?.warranty == 60 ? 'selected' : '' %>>60 Tháng</option>
                                                </select>
                                            </div>
                                            <div class="form-group full">
                                                <label class="form-label">Mô tả chi tiết</label>
                                                <textarea name="description" id="editor"><%= product?.description %></textarea>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Giá & Kho -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Giá bán & Tồn kho</span>
                                        </div>
                                        <div class="form-grid">
                                            <div class="form-group">
                                                <label class="form-label">Giá nhập (₫) <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="cost" class="form-input" type="number" id="inp-cost"
                                                    placeholder="VD: 20000000" min="0" oninput="calcMargin()" value="<%= product?.cost %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Giá bán (₫) <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="price" class="form-input" type="number" id="inp-price"
                                                    placeholder="VD: 34990000" min="0" oninput="calcMargin()" value="<%= product?.price %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Giá khuyến mãi (₫)</label>
                                                <input name="discountPrice" class="form-input" type="number"
                                                    id="inp-discount" placeholder="Để trống nếu không có" min="0">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Biên lợi nhuận</label>
                                                <div class="form-input"
                                                    style="background:var(--bg);color:var(--text-muted);cursor:default;"
                                                    id="margin-display">Nhập giá để tính</div>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Số lượng tồn kho <span
                                                        style="color:#E24B4A">*</span></label>
                                                <input name="stock" class="form-input" type="number" id="inp-stock"
                                                    placeholder="VD: 100" min="0" value="<%= product?.stock %>">
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Ngưỡng cảnh báo hết hàng</label>
                                                <input name="lowStockThreshold" class="form-input" type="number"
                                                    id="inp-stock-alert" placeholder="VD: 10" min="0" value="<%= product?.lowStockThreshold %>">
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Ảnh bìa sản phẩm -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Ảnh bìa sản phẩm</span>
                                            <span style="font-size:12px;color:var(--text-muted)">1 ảnh · PNG, JPG, WEBP
                                                · tối đa 5MB</span>
                                        </div>
                                        <div>
                                            <input type="hidden" name="existingCover" id="existingCover" value="<%= product?.image || '' %>">
                                            <input type="file" name="image" id="coverImageFile"
                                                accept=".jpg,.jpeg,.png,.webp" style="display:none;"
                                                onchange="handleCoverImage(this)">

                                            <!-- Drop zone (ẩn khi đã có preview) -->
                                            <label for="coverImageFile" id="coverDropZone"
                                                style="display:<%= product?.image ? 'none' : 'flex' %>;flex-direction:column;align-items:center;justify-content:center;border:2px dashed var(--border);border-radius:10px;padding:36px 24px;cursor:pointer;transition:all 0.2s;gap:8px;"
                                                onmouseover="this.style.borderColor='var(--accent)'"
                                                onmouseout="this.style.borderColor='var(--border)'">
                                                <div style="font-size:36px;">🖼️</div>
                                                <div style="font-size:13px;font-weight:600;">Kéo thả hoặc click để tải
                                                    ảnh bìa</div>
                                                <div style="font-size:11px;color:var(--text-muted);">Chỉ chọn 1 ảnh duy
                                                    nhất</div>
                                            </label>

                                            <!-- Preview ảnh bìa -->
                                            <div id="coverPreviewWrapper"
                                                style="display:<%= product?.image ? 'block' : 'none' %>;position:relative;border-radius:10px;overflow:hidden;border:1px solid var(--border);width:300px;height:300px;max-width:100%;margin:0 auto;">
                                                <img id="coverPreviewImg" src="<%= product?.image ? '/admin/productImages/' + product.image : '' %>" alt="Ảnh bìa"
                                                    style="width:100%;height:100%;object-fit:cover;display:block;">
                                                <div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);opacity:0;transition:opacity 0.2s;display:flex;align-items:center;justify-content:center;gap:10px;"
                                                    id="coverOverlay" onmouseover="this.style.opacity=1"
                                                    onmouseout="this.style.opacity=0">
                                                    <label for="coverImageFile"
                                                        style="cursor:pointer;background:rgba(255,255,255,0.15);color:#fff;border:1px solid rgba(255,255,255,0.4);border-radius:6px;padding:6px 14px;font-size:12px;font-weight:500;backdrop-filter:blur(4px);transition:background 0.2s;"
                                                        onmouseover="this.style.background='rgba(255,255,255,0.28)'"
                                                        onmouseout="this.style.background='rgba(255,255,255,0.15)'">
                                                        🔄 Đổi ảnh
                                                    </label>
                                                    <button type="button" onclick="removeCoverImage()"
                                                        style="cursor:pointer;background:rgba(226,75,74,0.75);color:#fff;border:1px solid rgba(226,75,74,0.5);border-radius:6px;padding:6px 14px;font-size:12px;font-weight:500;backdrop-filter:blur(4px);transition:background 0.2s;"
                                                        onmouseover="this.style.background='rgba(226,75,74,1)'"
                                                        onmouseout="this.style.background='rgba(226,75,74,0.75)'">
                                                        🗑 Xóa
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Ảnh sản phẩm (nhiều ảnh) -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:16px;">
                                            <span class="card-title">Ảnh sản phẩm</span>
                                            <span style="font-size:12px;color:var(--text-muted)">Nhiều ảnh · PNG, JPG,
                                                WEBP · tối đa 5MB/ảnh</span>
                                        </div>

                                        <!-- Drop zone -->
                                        <label for="productImagesFile" id="productDropZone"
                                            style="display:flex;flex-direction:column;align-items:center;justify-content:center;border:2px dashed var(--border);border-radius:10px;padding:28px 24px;cursor:pointer;transition:all 0.2s;gap:6px;margin-bottom:14px;"
                                            onmouseover="this.style.borderColor='var(--accent)'"
                                            onmouseout="this.style.borderColor='var(--border)'">
                                            <div style="font-size:30px;">📸</div>
                                            <div style="font-size:13px;font-weight:600;">Click hoặc kéo thả ảnh vào đây
                                            </div>
                                            <div style="font-size:11px;color:var(--text-muted);">Chọn nhiều ảnh cùng lúc
                                                (Ctrl + Click)</div>
                                        </label>
                                        <input type="file" name="images" id="productImagesFile"
                                            accept=".jpg,.jpeg,.png,.webp" multiple style="display:none;"
                                            onchange="handleProductImages(this)">

                                        <!-- Grid preview -->
                                        <div id="productImagesGrid"
                                            style="display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:10px;">
                                        </div>

                                        <!-- Đếm số ảnh -->
                                        <div id="productImagesCount"
                                            style="display:none;font-size:11px;color:var(--text-muted);margin-top:10px;text-align:right;">
                                        </div>
                                    </div>

                                    <!-- Thông số kỹ thuật -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:20px;">
                                            <span class="card-title">Thông số kỹ thuật</span>
                                            <button type="button" class="btn sm" onclick="addSpec()">+ Thêm thông
                                                số</button>
                                        </div>
                                        <div id="spec-list" style="display:flex;flex-direction:column;gap:10px;">
                                            <% if (product?.specifications && product.specifications.length > 0) { %>
                                                <% product.specifications.forEach(function(spec) { %>
                                                    <div class="spec-row" style="display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:center;">
                                                        <select name="specKey[]" class="form-input spec-key-select" onchange="handleSpecKeyChange(this)" data-selected="<%= spec.key %>">
                                                            <option value="">-- Chọn thông số --</option>
                                                        </select>
                                                        <input type="text" name="specKeyCustom[]" class="form-input spec-key-custom" placeholder="Nhập tên thông số..." style="display:none;" disabled value="<%= spec.key %>">

                                                        <input type="text" name="specValue[]" class="form-input spec-value-text" placeholder="Nhập giá trị..." value="<%= spec.value %>">
                                                        <select name="" class="form-input spec-value-select" style="display:none;" disabled data-selected="<%= spec.value %>">
                                                            <option value="">-- Chọn sản phẩm --</option>
                                                        </select>
                                                        <select name="" class="form-input spec-value-options" style="display:none;" disabled>
                                                            <option value="">-- Chọn giá trị --</option>
                                                        </select>
                                                        <div class="spec-value-watt" style="display:none;flex-direction:row;align-items:stretch;border-radius:6px;overflow:hidden;border:1px solid var(--border);background:var(--card-bg);">
                                                            <input type="number" class="spec-value-watt-num" min="0" step="1" style="flex:1;border:none;background:transparent;color:var(--text);padding:8px 10px;font-size:13px;outline:none;width:100%;" placeholder="125" oninput="syncWattValue(this)">
                                                            <span style="background:var(--accent);color:#fff;padding:8px 12px;font-size:12px;font-weight:700;display:flex;align-items:center;white-space:nowrap;">W</span>
                                                            <input type="hidden" name="" class="spec-value-watt-hidden" disabled>
                                                        </div>

                                                        <button type="button" class="btn sm danger-outline" onclick="removeSpec(this)">✕</button>
                                                    </div>
                                                <% }); %>
                                            <% } else { %>
                                                <div class="spec-row" style="display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:center;">
                                                    <select name="specKey[]" class="form-input spec-key-select" onchange="handleSpecKeyChange(this)">
                                                        <option value="">-- Chọn thông số --</option>
                                                    </select>
                                                    <input type="text" name="specKeyCustom[]" class="form-input spec-key-custom" placeholder="Nhập tên thông số..." style="display:none;" disabled>

                                                    <input type="text" name="specValue[]" class="form-input spec-value-text" placeholder="Nhập giá trị...">
                                                    <select name="" class="form-input spec-value-select" style="display:none;" disabled>
                                                        <option value="">-- Chọn sản phẩm --</option>
                                                    </select>
                                                    <select name="" class="form-input spec-value-options" style="display:none;" disabled>
                                                        <option value="">-- Chọn giá trị --</option>
                                                    </select>
                                                    <div class="spec-value-watt" style="display:none;flex-direction:row;align-items:stretch;border-radius:6px;overflow:hidden;border:1px solid var(--border);background:var(--card-bg);">
                                                        <input type="number" class="spec-value-watt-num" min="0" step="1" style="flex:1;border:none;background:transparent;color:var(--text);padding:8px 10px;font-size:13px;outline:none;width:100%;" placeholder="125" oninput="syncWattValue(this)">
                                                        <span style="background:var(--accent);color:#fff;padding:8px 12px;font-size:12px;font-weight:700;display:flex;align-items:center;white-space:nowrap;">W</span>
                                                        <input type="hidden" name="" class="spec-value-watt-hidden" disabled>
                                                    </div>

                                                    <button type="button" class="btn sm danger-outline" onclick="removeSpec(this)">✕</button>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>

                                </div>

                                <!-- Right: Status & Actions -->
                                <div style="display:flex;flex-direction:column;gap:16px;">

                                    <!-- Lượt xem & Thống kê đánh giá -->
                                    <div class="card" style="background:linear-gradient(135deg,var(--card-bg) 0%,rgba(99,102,241,0.04) 100%);">
                                        <div class="card-header" style="margin-bottom:16px;"><span class="card-title">📊 Thống kê</span></div>
                                        <div style="display:flex;flex-direction:column;gap:12px;">
                                            <!-- Lượt xem -->
                                            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(99,102,241,0.08);border-radius:8px;">
                                                <div style="display:flex;align-items:center;gap:8px;">
                                                    <span style="font-size:18px;">👁️</span>
                                                    <span style="font-size:12px;color:var(--text-muted);font-weight:500;">Lượt xem</span>
                                                </div>
                                                <span id="view-count-display" style="font-size:20px;font-weight:700;color:var(--accent);"><%= product?.viewCount ?? 0 %></span>
                                            </div>
                                            <!-- Tổng đánh giá -->
                                            <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(234,179,8,0.08);border-radius:8px;">
                                                <div style="display:flex;align-items:center;gap:8px;">
                                                    <span style="font-size:18px;">⭐</span>
                                                    <span style="font-size:12px;color:var(--text-muted);font-weight:500;">Điểm TB</span>
                                                </div>
                                                <div style="text-align:right;">
                                                    <div style="font-size:20px;font-weight:700;color:#ca8a04;"><%= reviewStats?.avgRating ?? 0 %> <span style="font-size:12px;font-weight:400;color:var(--text-muted);">/ 5</span></div>
                                                    <div style="font-size:11px;color:var(--text-muted);"><%= reviewStats?.total ?? 0 %> đánh giá</div>
                                                </div>
                                            </div>
                                            <!-- Phân bố sao -->
                                            <% if (reviewStats && reviewStats.total > 0) { %>
                                            <div style="display:flex;flex-direction:column;gap:5px;padding:8px 0;">
                                                <% [5,4,3,2,1].forEach(function(star){ %>
                                                <div style="display:flex;align-items:center;gap:6px;font-size:11px;">
                                                    <span style="width:28px;text-align:right;color:var(--text-muted);"><%= star %>★</span>
                                                    <div style="flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden;">
                                                        <div style="height:100%;border-radius:3px;background:<%= star>=4?'#22c55e':star===3?'#eab308':'#ef4444' %>;width:<%= reviewStats.total>0?Math.round((reviewStats.ratingDist[star]/reviewStats.total)*100):0 %>%;"></div>
                                                    </div>
                                                    <span style="width:22px;color:var(--text-muted);"><%= reviewStats.ratingDist[star] %></span>
                                                </div>
                                                <% }); %>
                                            </div>
                                            <% } %>
                                            <!-- Trạng thái duyệt -->
                                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                                <span style="flex:1;text-align:center;padding:6px;border-radius:6px;background:rgba(234,179,8,0.12);font-size:11px;font-weight:600;color:#ca8a04;">⏳ <%= reviewStats?.pending ?? 0 %> chờ</span>
                                                <span style="flex:1;text-align:center;padding:6px;border-radius:6px;background:rgba(34,197,94,0.12);font-size:11px;font-weight:600;color:#16a34a;">✓ <%= reviewStats?.approved ?? 0 %> duyệt</span>
                                                <span style="flex:1;text-align:center;padding:6px;border-radius:6px;background:rgba(239,68,68,0.12);font-size:11px;font-weight:600;color:#dc2626;">✕ <%= reviewStats?.rejected ?? 0 %> từ chối</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Trạng thái -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:16px;"><span
                                                class="card-title">Trạng thái sản phẩm</span>
                                        </div>
                                        <div style="display:flex;flex-direction:column;gap:8px;">
                                            <label
                                                style="display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--accent);border-radius:8px;cursor:pointer;"
                                                id="status-active-lbl">
                                                <input type="radio" name="status" value="ACTIVE" <%= (!product || product.status === 'ACTIVE') ? 'checked' : '' %>
                                                    onchange="selectStatus('active')"
                                                    style="accent-color:var(--accent);">
                                                <div>
                                                    <div style="font-size:13px;font-weight:500;">Đang bán</div>
                                                    <div style="font-size:11px;color:var(--text-muted);">Hiển thị & cho
                                                        phép đặt hàng</div>
                                                </div>
                                            </label>
                                            <label
                                                style="display:flex;align-items:center;gap:10px;padding:10px;border:1px solid var(--border);border-radius:8px;cursor:pointer;"
                                                id="status-inactive-lbl">
                                                <input type="radio" name="status" value="INACTIVE" <%= product?.status === 'INACTIVE' ? 'checked' : '' %>
                                                    onchange="selectStatus('inactive')"
                                                    style="accent-color:var(--accent);">
                                                <div>
                                                    <div style="font-size:13px;font-weight:500;">Ngưng bán</div>
                                                    <div style="font-size:11px;color:var(--text-muted);">Ẩn khỏi cửa
                                                        hàng</div>
                                                </div>
                                            </label>
                                        </div>
                                    </div>

                                    <!-- Thuộc tính nổi bật -->
                                    <div class="card">
                                        <div class="card-header" style="margin-bottom:16px;"><span
                                                class="card-title">Thuộc tính</span></div>
                                        <div style="display:flex;flex-direction:column;gap:10px;">
                                            <label
                                                style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;">
                                                <input type="checkbox" name="isFeatured" id="inp-featured"
                                                    style="width:14px;height:14px;accent-color:var(--accent);" <%= product?.isFeatured ? 'checked' : '' %>>
