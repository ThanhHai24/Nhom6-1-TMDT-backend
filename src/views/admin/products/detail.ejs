            function getCategoryKey() {
                const select = document.getElementById('inp-category');
                const option = select.options[select.selectedIndex];
                if (!option || !option.value) return 'default';
                const slug = option.getAttribute('data-slug') || '';
                const name = option.getAttribute('data-name') || '';
                
                if (slug.includes('pc') || name.includes('pc') || name.includes('máy tính bộ') || name.includes('build')) return 'pc';
                if (slug.includes('cpu') || name.includes('cpu') || name.includes('vi xử lý')) return 'cpu';
                if (slug.includes('main') || name.includes('main') || name.includes('bo mạch')) return 'mainboard';
                if (slug.includes('ram') || name.includes('ram') || name.includes('bộ nhớ trong')) return 'ram';
                if (slug.includes('vga') || name.includes('card') || name.includes('đồ họa')) return 'vga';
                if (slug.includes('psu') || name.includes('nguồn')) return 'psu';
                if (slug.includes('case') || name.includes('vỏ')) return 'case';
                if (slug.includes('cooler') || slug.includes('tan-nhiet') || name.includes('tản nhiệt')) return 'cooler';
                if (slug.includes('ssd') || slug.includes('hdd') || name.includes('ổ cứng')) return 'storage';
                if (slug.includes('man-hinh') || name.includes('màn hình')) return 'monitor';
                return 'default';
            }

            function updateSpecDropdowns() {
                const key = getCategoryKey();
                const specs = specTemplates[key] || specTemplates['default'];
                const selects = document.querySelectorAll('.spec-key-select');
                
                selects.forEach(select => {
                    let currentValue = select.getAttribute('data-selected') || select.value;
                    select.removeAttribute('data-selected'); // Clear it so subsequent changes use select.value
                    
                    let isCustom = currentValue && !specs.includes(currentValue);
                    
                    let html = '<option value="">-- Chọn thông số --</option>';
                    specs.forEach(s => {
                        html += `<option value="${s}" ${currentValue === s ? 'selected' : ''}>${s}</option>`;
                    });
                    html += `<option value="custom" ${isCustom ? 'selected' : ''}>Khác (Tùy chỉnh...)</option>`;
                    select.innerHTML = html;
                    
                    if (isCustom) {
                        select.value = 'custom';
                    }
                    handleSpecKeyChange(select, true);
                });
            }

            // ── Đồng bộ giá trị Watt → hidden input ──────────────────────────
            function syncWattValue(numInput) {
                const wattDiv = numInput.closest('.spec-value-watt');
                const hidden = wattDiv.querySelector('.spec-value-watt-hidden');
                hidden.value = numInput.value !== '' ? numInput.value + 'W' : '';
            }

            // ── Đặt chế độ hiển thị cho ô giá trị trong 1 spec-row ────────────
            function setSpecValueMode(row, mode, extraData, currentValue) {
                const textEl    = row.querySelector('.spec-value-text');
                const selectEl  = row.querySelector('.spec-value-select');
                const optionsEl = row.querySelector('.spec-value-options');
                const wattDiv   = row.querySelector('.spec-value-watt');
                const wattNum   = row.querySelector('.spec-value-watt-num');
                const wattHid   = row.querySelector('.spec-value-watt-hidden');

                [textEl, selectEl, optionsEl].forEach(el => {
                    if (!el) return;
                    el.style.display = 'none'; el.disabled = true; el.name = '';
                });
                if (wattDiv) wattDiv.style.display = 'none';
                if (wattHid) { wattHid.disabled = true; wattHid.name = ''; }

                // ưu tiên currentValue, nếu không có thì lấy từ textEl (dùng khi init từ EJS)
                const existVal = (currentValue !== undefined && currentValue !== null) ? currentValue
                    : (textEl ? textEl.value : '');

                if (mode === 'text') {
                    textEl.style.display = 'block'; textEl.disabled = false; textEl.name = 'specValue[]';
                    if (existVal && !textEl.value) textEl.value = existVal;

                } else if (mode === 'product') {
                    const prevId = (selectEl ? selectEl.getAttribute('data-selected') : '') || existVal;
                    selectEl.style.display = 'block'; selectEl.disabled = false; selectEl.name = 'specValue[]';
                    let html = '<option value="">-- Chọn sản phẩm --</option>';
                    (extraData || []).forEach(p => {
                        html += `<option value="${p.id}"${String(prevId) === String(p.id) ? ' selected' : ''}>${p.name}</option>`;
                    });
                    selectEl.innerHTML = html;
                    if (selectEl) selectEl.removeAttribute('data-selected');

                } else if (mode === 'options') {
                    optionsEl.style.display = 'block'; optionsEl.disabled = false; optionsEl.name = 'specValue[]';
                    const opts = extraData || [];
                    let html = '<option value="">-- Chọn giá trị --</option>';
                    opts.forEach(opt => html += `<option value="${opt}"${existVal === opt ? ' selected' : ''}>${opt}</option>`);
                    if (existVal && !opts.includes(existVal)) {
                        html += `<option value="${existVal}" selected>${existVal} (giữ nguyên)</option>`;
                    }
                    optionsEl.innerHTML = html;
                    if (existVal) optionsEl.value = existVal;

                } else if (mode === 'watt') {
                    wattDiv.style.display = 'flex'; wattHid.disabled = false; wattHid.name = 'specValue[]';
                    const numVal = existVal ? parseInt(String(existVal).replace(/[^0-9]/g, '')) : '';
                    if (wattNum) wattNum.value = numVal || '';
                    wattHid.value = numVal ? numVal + 'W' : '';
                }
            }

            function handleSpecKeyChange(select, init = false) {
                const row = select.closest('.spec-row');
                const customInput = row.querySelector('.spec-key-custom');

                if (select.value === 'custom') {
                    select.style.display = 'none'; select.disabled = true; select.name = '';
                    customInput.style.display = 'block'; customInput.disabled = false; customInput.name = 'specKey[]';
                    if (!init) customInput.focus();
                    setSpecValueMode(row, 'text', null, null);
                    return;
                } else {
                    select.style.display = 'block'; select.disabled = false; select.name = 'specKey[]';
                    customInput.style.display = 'none'; customInput.disabled = true; customInput.name = 'specKeyCustom[]';
                }

                const catKey = getCategoryKey();
                const specKey = select.value;

                if (catKey === 'pc' && specKey) {
                    const compType = specKey.toLowerCase();
                    const filtered = allStoreProducts.filter(p => {
                        const cN = p.categoryName.toLowerCase(), cS = p.categorySlug.toLowerCase();
                        if (compType === 'cpu'           && (cS.includes('cpu')  || cN.includes('cpu')  || cN.includes('vi xử lý')))  return true;
                        if (compType === 'mainboard'     && (cS.includes('main') || cN.includes('main') || cN.includes('bo mạch')))    return true;
                        if (compType === 'ram'           && (cS.includes('ram')  || cN.includes('ram')  || cN.includes('bộ nhớ')))    return true;
                        if (compType === 'vga'           && (cS.includes('vga')  || cN.includes('card') || cN.includes('đồ họa')))    return true;
                        if (compType === 'ssd'           && (cS.includes('ssd')  || cN.includes('ssd')))                              return true;
                        if (compType === 'hdd'           && (cS.includes('hdd')  || cN.includes('hdd')))                              return true;
                        if (compType.includes('nguồn')   && (cS.includes('psu')  || cN.includes('nguồn')))                            return true;
                        if (compType.includes('case')    && (cS.includes('case') || cN.includes('vỏ')))                               return true;
                        if (compType.includes('tản nhiệt') && (cS.includes('cooler') || cN.includes('tản nhiệt')))                   return true;
                        if (compType.includes('màn hình')   && (cS.includes('man-hinh') || cN.includes('màn hình')))                  return true;
                        return false;
                    });
                    setSpecValueMode(row, 'product', filtered, null);
                    return;
                }

                const conf = specValueConfig[specKey];
                if (conf) {
                    if (conf.type === 'watt')    { setSpecValueMode(row, 'watt',    null,         null); return; }
                    if (conf.type === 'options') { setSpecValueMode(row, 'options', conf.options, null); return; }
                }
                setSpecValueMode(row, 'text', null, null);
            }

            document.addEventListener('DOMContentLoaded', () => {
                updateSpecDropdowns();
            });
            /* =============================================
               ẢNH BÌA – chỉ 1 ảnh
            ============================================= */
            function handleCoverImage(input) {
                const file = input.files[0];
                if (!file) return;
                const url = URL.createObjectURL(file);
                document.getElementById('coverPreviewImg').src = url;
                document.getElementById('coverDropZone').style.display = 'none';
                document.getElementById('coverPreviewWrapper').style.display = 'block';
            }

            function removeCoverImage() {
                document.getElementById('coverImageFile').value = '';
                document.getElementById('coverPreviewImg').src = '';
                document.getElementById('coverPreviewWrapper').style.display = 'none';
                document.getElementById('coverDropZone').style.display = 'flex';
                
                const existingCover = document.getElementById('existingCover');
                if (existingCover) existingCover.value = '';
            }

            function removeExistingImage(btn) {
                btn.parentElement.remove();
            }

            /* =============================================
               ẢNH SẢN PHẨM – nhiều ảnh, có preview + xóa
            ============================================= */
            let productFiles = []; // DataTransfer để quản lý files

            function handleProductImages(input) {
                const newFiles = Array.from(input.files);
                newFiles.forEach(f => productFiles.push(f));
                renderProductPreviews();
            }

            function removeProductImage(index) {
                productFiles.splice(index, 1);
                renderProductPreviews();
            }

            function syncProductFilesInput() {
                const dt = new DataTransfer();
                productFiles.forEach(f => dt.items.add(f));
                document.getElementById('productImagesFile').files = dt.files;
            }

            function renderProductPreviews() {
                const grid = document.getElementById('productImagesGrid');
                const counter = document.getElementById('productImagesCount');
                grid.innerHTML = '';

                productFiles.forEach((file, idx) => {
                    const url = URL.createObjectURL(file);
                    const cell = document.createElement('div');
                    cell.style.cssText = 'position:relative;border-radius:8px;overflow:hidden;border:1px solid var(--border);aspect-ratio:1;background:var(--bg);';
                    cell.innerHTML = `
                        <img src="${url}" alt="Ảnh ${idx + 1}"
                            style="width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.2s;"
                            onmouseover="this.style.transform='scale(1.06)'"
                            onmouseout="this.style.transform='scale(1)'">
                        <button type="button" onclick="removeProductImage(${idx})"
                            title="Xóa ảnh này"
                            style="position:absolute;top:4px;right:4px;width:22px;height:22px;border-radius:50%;background:rgba(226,75,74,0.85);color:#fff;border:none;cursor:pointer;font-size:13px;line-height:1;display:flex;align-items:center;justify-content:center;transition:all 0.15s;backdrop-filter:blur(2px);"
                            onmouseover="this.style.background='rgba(226,75,74,1)';this.style.transform='scale(1.15)'"
                            onmouseout="this.style.background='rgba(226,75,74,0.85)';this.style.transform='scale(1)'">✕</button>
                        <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.5);color:#fff;font-size:9px;padding:2px 4px;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${file.name}</div>
                    `;
                    grid.appendChild(cell);
                });

                if (productFiles.length > 0) {
                    counter.style.display = 'block';
                    counter.textContent = `Đã chọn: ${productFiles.length} ảnh`;
                } else {
                    counter.style.display = 'none';
                }
                syncProductFilesInput();
            }
        </script>
        <script>
            function selectStatus(val) {
                ['active', 'draft', 'inactive'].forEach(s => {
                    const lbl = document.getElementById('status-' + s + '-lbl');
                    if (lbl) lbl.style.borderColor = s === val ? 'var(--accent)' : 'var(--border)';
                });
            }

            function calcMargin() {
                const cost = parseFloat(document.getElementById('inp-cost').value) || 0;
                const price = parseFloat(document.getElementById('inp-price').value) || 0;
                const el = document.getElementById('margin-display');
                if (cost > 0 && price > 0) {
                    const margin = ((price - cost) / price * 100).toFixed(1);
                    const profit = (price - cost).toLocaleString('vi-VN');
                    el.textContent = margin + '% (' + profit + ' ₫)';
                    el.style.color = price >= cost ? '#1D9E75' : '#E24B4A';
                } else {
                    el.textContent = 'Nhập giá để tính';
                    el.style.color = 'var(--text-muted)';
                }
            }

            function addSpec() {
                const list = document.getElementById('spec-list');
                const row  = document.createElement('div');
                row.className = 'spec-row';
                row.style.cssText = 'display:grid;grid-template-columns:1fr 1fr auto;gap:10px;align-items:center;';

                const key  = getCategoryKey();
                const specs = specTemplates[key] || specTemplates['default'];
                let optsHtml = '<option value="">-- Chọn thông số --</option>';
                specs.forEach(s => optsHtml += `<option value="${s}">${s}</option>`);
                optsHtml += '<option value="custom">Khác (Tùy chỉnh...)</option>';

                row.innerHTML = `
                    <select name="specKey[]" class="form-input spec-key-select" onchange="handleSpecKeyChange(this)">${optsHtml}</select>
                    <input type="text" name="specKeyCustom[]" class="form-input spec-key-custom" placeholder="Nhập tên thông số..." style="display:none;" disabled>

                    <input type="text" name="specValue[]" class="form-input spec-value-text" placeholder="Nhập giá trị...">
                    <select name="" class="form-input spec-value-select" style="display:none;" disabled>
                        <option value="">-- Chọn sản phẩm --</option>
                    </select>
                    <select name="" class="form-input spec-value-options" style="display:none;" disabled>
                        <option value="">-- Chọn giá trị --</option>
                    </select>
                    <div class="spec-value-watt" style="display:none;flex-direction:row;align-items:stretch;border-radius:6px;overflow:hidden;border:1px solid var(--border);background:var(--card-bg);">
                        <input type="number" class="spec-value-watt-num" min="0" step="1" style="flex:1;border:none;background:transparent;color:var(--text);padding:8px 10px;font-size:13px;outline:none;width:100%;" placeholder="125" oninput="syncWattValue(this)">
                        <span style="background:var(--accent);color:#fff;padding:8px 12px;font-size:12px;font-weight:700;display:flex;align-items:center;white-space:nowrap;">W</span>
                        <input type="hidden" name="" class="spec-value-watt-hidden" disabled>
                    </div>

                    <button type="button" class="btn sm danger-outline" onclick="removeSpec(this)">✕</button>
                `;
                list.appendChild(row);
                handleSpecKeyChange(row.querySelector('.spec-key-select'), false);
            }

            function removeSpec(btn) {
                const rows = document.querySelectorAll('.spec-row');
                if (rows.length > 1) btn.closest('.spec-row').remove();
            }

            function submitAddProduct(event) {
                const errors = [];
                const name = document.getElementById('inp-name').value.trim();
                const category = document.getElementById('inp-category').value;
                const cost = document.getElementById('inp-cost').value;
                const price = document.getElementById('inp-price').value;
                const stock = document.getElementById('inp-stock').value;

                if (!name) errors.push('Tên sản phẩm không được để trống');
                if (!category) errors.push('Vui lòng chọn danh mục sản phẩm');
                if (!cost || parseFloat(cost) < 0) errors.push('Giá nhập không hợp lệ');
                if (!price || parseFloat(price) < 0) errors.push('Giá bán không hợp lệ');
                if (!stock || parseInt(stock) < 0) errors.push('Số lượng tồn kho không hợp lệ');

                const errBox = document.getElementById('form-errors');
                const errList = document.getElementById('error-list');
                if (errors.length > 0) {
                    event.preventDefault();
                    errList.innerHTML = errors.map(e => '<li>' + e + '</li>').join('');
                    errBox.style.display = 'block';
                    errBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }
                errBox.style.display = 'none';

                const btn = event.submitter;
                btn.textContent = 'Đang lưu...';
                btn.disabled = true;
            }
        </script>

