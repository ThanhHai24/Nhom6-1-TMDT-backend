                        <div class="card" style="margin-top:20px;">
                            <div class="card-header" style="margin-bottom:20px;align-items:flex-start;">
                                <div>
                                    <span class="card-title">⭐ Đánh giá & Bình luận</span>
                                    <div style="font-size:12px;color:var(--text-muted);margin-top:4px;"><%= product?.reviews?.length ?? 0 %> đánh giá · Điểm trung bình: <strong><%= reviewStats?.avgRating ?? 0 %>/5</strong></div>
                                </div>
                                <a href="/admin/reviews" style="font-size:12px;color:var(--accent);text-decoration:none;">Xem tất cả →</a>
                            </div>

                            <% if (!product?.reviews || product.reviews.length === 0) { %>
                            <div style="text-align:center;padding:40px 20px;color:var(--text-muted);">
                                <div style="font-size:40px;margin-bottom:12px;">💬</div>
                                <div style="font-size:14px;font-weight:500;">Chưa có đánh giá nào</div>
                                <div style="font-size:12px;margin-top:4px;">Khách hàng chưa gửi đánh giá cho sản phẩm này</div>
                            </div>
                            <% } else { %>
                            <div style="display:flex;flex-direction:column;gap:12px;">
                                <% product.reviews.forEach(function(review){ %>
                                <%
                                    const statusColor = review.status === 'APPROVED' ? '#16a34a' : review.status === 'REJECTED' ? '#dc2626' : '#ca8a04';
                                    const statusBg   = review.status === 'APPROVED' ? 'rgba(34,197,94,0.1)' : review.status === 'REJECTED' ? 'rgba(239,68,68,0.1)' : 'rgba(234,179,8,0.1)';
                                    const statusLabel = review.status === 'APPROVED' ? 'Đã duyệt' : review.status === 'REJECTED' ? 'Từ chối' : 'Chờ duyệt';
                                %>
                                <div style="border:1px solid var(--border);border-radius:10px;padding:14px 16px;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 2px 12px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
                                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
                                        <!-- User info -->
                                        <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                                            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#8b5cf6);display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;font-weight:700;flex-shrink:0;">
                                                <%= review.user ? review.user.fullName?.charAt(0)?.toUpperCase() : 'K' %>
                                            </div>
                                            <div style="min-width:0;">
                                                <div style="font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= review.user ? review.user.fullName : 'Khách ẩn danh' %></div>
                                                <div style="font-size:11px;color:var(--text-muted);"><%= review.user?.email ?? '' %></div>
                                            </div>
                                        </div>
                                        <!-- Rating & date -->
                                        <div style="text-align:right;flex-shrink:0;">
                                            <div style="font-size:14px;color:#eab308;letter-spacing:1px;">
                                                <% for(let s=1;s<=5;s++){ %><%= s <= review.rating ? '★' : '☆' %><% } %>
                                            </div>
                                            <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">
                                                <%= review.createdAt ? new Date(review.createdAt).toLocaleDateString('vi-VN') : '' %>
                                            </div>
                                        </div>
                                    </div>

                                    <% if (review.title) { %>
                                    <div style="font-size:13px;font-weight:600;margin-top:10px;"><%= review.title %></div>
                                    <% } %>
                                    <% if (review.comment) { %>
                                    <div style="font-size:13px;color:var(--text-muted);margin-top:6px;line-height:1.6;"><%= review.comment %></div>
                                    <% } %>

                                    <!-- Actions -->
                                    <div style="display:flex;align-items:center;justify-content:space-between;margin-top:12px;padding-top:10px;border-top:1px solid var(--border);">
                                        <span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;background:<%= statusBg %>;color:<%= statusColor %>;"><%= statusLabel %></span>
                                        <div style="display:flex;gap:6px;">
                                            <% if(review.status !== 'APPROVED') { %>
                                            <form action="/admin/reviews/approve/<%= review.id %>" method="post" style="display:inline;">
                                                <button class="btn sm" style="background:rgba(34,197,94,0.12);color:#16a34a;border:1px solid rgba(34,197,94,0.3);" onmouseover="this.style.background='rgba(34,197,94,0.25)'" onmouseout="this.style.background='rgba(34,197,94,0.12)'">✓ Duyệt</button>
                                            </form>
                                            <% } %>
                                            <% if(review.status !== 'REJECTED') { %>
                                            <form action="/admin/reviews/reject/<%= review.id %>" method="post" style="display:inline;">
                                                <button class="btn sm" style="background:rgba(234,179,8,0.12);color:#ca8a04;border:1px solid rgba(234,179,8,0.3);" onmouseover="this.style.background='rgba(234,179,8,0.25)'" onmouseout="this.style.background='rgba(234,179,8,0.12)'">↩ Từ chối</button>
                                            </form>
                                            <% } %>
                                            <form action="/admin/reviews/delete/<%= review.id %>" method="post" style="display:inline;" onsubmit="return confirm('Xóa đánh giá này?')">
                                                <button class="btn sm danger-outline">🗑 Xóa</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                            <% } %>
                        </div>
                        <!-- ===== END REVIEWS ===== -->

                    </div>

        </main>
        <script src="https://cdn.ckeditor.com/ckeditor5/48.0.0/ckeditor5.umd.js" crossorigin></script>
