        <script>
            // Gọi API tăng lượt xem khi trang load (client-side, Option B)
            (function(){
                const productId = '<%= product?.id %>';
                if (!productId) return;
                fetch('/admin/products/view/' + productId, { method: 'POST', headers: { 'Content-Type': 'application/json' } })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            const el = document.getElementById('view-count-display');
                            if (el) el.textContent = parseInt(el.textContent || '0') + 1;
                        }
                    })
                    .catch(() => {});
            })();
        </script>

        <script>
            document.addEventListener("DOMContentLoaded", () => {
                calcMargin();
                selectStatus('<%= (product?.status || "ACTIVE").toLowerCase() %>');

                /* === Filter brands theo category khi load trang === */
                const _allBrandsData = <%- JSON.stringify((brands || []).map(b => ({ id: Number(b.id), name: b.name }))) %>;
                const _currentBrandId = '<%= product?.brandId ? Number(product.brandId) : "" %>';
                const _currentCategoryId = '<%= product?.categoryId ? Number(product.categoryId) : "" %>';

                function renderBrandOptions(brandList, selectedId) {
                    const sel = document.getElementById('inp-brand');
                    let html = '<option value="">-- Chọn Thương hiệu --</option>';
                    brandList.forEach(b => {
                        const sid = String(b.id);
                        html += `<option value="${sid}" ${sid === String(selectedId) ? 'selected' : ''}>${b.name}</option>`;
                    });
                    sel.innerHTML = html;
                }

                window.filterBrandsByCategory = async function() {
                    const categoryId = document.getElementById('inp-category').value;
                    const loading = document.getElementById('brand-loading');
                    const currentBrand = document.getElementById('inp-brand').value || _currentBrandId;

                    if (!categoryId) {
                        renderBrandOptions(_allBrandsData, currentBrand);
                        return;
                    }

                    loading.style.display = 'block';
                    try {
                        const res = await fetch(`/admin/api/brands?categoryId=${categoryId}`);
                        const brands = await res.json();
                        if (brands.length === 0) {
                            renderBrandOptions(_allBrandsData, currentBrand);
                        } else {
                            renderBrandOptions(brands, currentBrand);
                        }
                    } catch (e) {
                        renderBrandOptions(_allBrandsData, currentBrand);
                    } finally {
                        loading.style.display = 'none';
                    }
                };

                // Filter brands ngay khi load trang
                if (_currentCategoryId) {
                    filterBrandsByCategory();
                }
                <% if (product?.images) { 
                    try {
                        const imgs = JSON.parse(product.images);
                        if (imgs.length > 0) {
                            %>
